      "parameters": [
        {
          "name": "",
          "type": "uint32_t",
          "description": ""
        }
      ],
      "function_body": "{\n    USB_LOG_RAW(\"    ER(addr:%X)\\r\\n\", addr);\n    FSHC_CACHE_DISABLE();\n    \n    fshc_erase(addr & 0xFFFFFF, FSH_CMD_ER_SECTOR);\n\n    FSHC_CACHE_RESTORE();\n    return 0;\n}",
