    {
      "name": "dfu_write_flash",
      "return_type": "uint16_t",
      "parameters": [
        {
          "name": "src",
          "type": "uint8_t",
          "description": ""
        },
        {
          "name": "dest",
          "type": "uint8_t",
          "description": ""
        },
        {
          "name": "",
          "type": "uint32_t",
          "description": ""
        }
      ],
      "function_body": "{\n    uint32_t offset = ((uint32_t)dest) & 0xFFFFFF;\n    \n    USB_LOG_RAW(\"    WR(src:%p,dst:%p,len:%d)\\r\\n\", src, dest, len);\n    uint32_t nb_page = PAGE_NB(len);\n    for (uint32_t page_idx = 0; page_idx < nb_page; ++page_idx)\n    {\n        dfu_page_write(offset + (page_idx * PAGE_SIZE), (uint32_t *)(src + (page_idx * PAGE_SIZE)), PAGE_SIZE_WLEN);\n    }\n    return 0;\n}",
      "file_path": "./usb\\src\\demo_dfu.c",
      "line_number": 248,
      "is_static": false
    },
