{
  "file_path": "./usb\\src\\demo_hid_boot.c",
  "functions": [
    {
      "name": "usbd_notify_handler",
      "return_type": "__USBIRQ",
      "parameters": [
        {
          "name": "",
          "type": "uint8_t",
          "description": ""
        },
        {
          "name": "arg",
          "type": "void",
          "description": ""
        }
      ],
      "function_body": "{\n    switch (event) {\n        case USBD_EVENT_RESET:\n            suspend = false;\n            usbd_hid_reset();\n            break;\n        case USBD_EVENT_RESUME:\n            suspend = false;\n            break;\n        case USBD_EVENT_SUSPEND:\n            suspend = true;\n            break;\n\n        default:\n            break;\n    }\n}",
      "file_path": "./usb\\src\\demo_hid_boot.c",
      "line_number": 279,
      "is_static": false
    },
    {
      "name": "hid_keybd_send_report",
      "return_type": "uint8_t",
      "parameters": [
        {
          "name": "",
          "type": "uint8_t",
          "description": ""
        }
      ],
      "function_body": "{\n    uint8_t ret = 0;\n    \n    #if (ENB_KEYBD)\n    uint8_t kyebd_report[8] = { 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 }; //A\n    \n    kyebd_report[2] = code;\n    \n    ret = usbd_hid_send_report(KEYBD_IN_EP, 8, kyebd_report);\n    USB_LOG_RAW(\"keybd(k:%d,ret:%d)\\r\\n\", code, ret);\n    #endif\n    \n    return ret;\n}",
      "file_path": "./usb\\src\\demo_hid_boot.c",
      "line_number": 304,
      "is_static": false
    },
    {
      "name": "hid_mouse_send_report",
      "return_type": "uint8_t",
      "parameters": [
        {
          "name": "",
          "type": "int8_t",
          "description": ""
        }
      ],
      "function_body": "{\n    uint8_t ret = 0;\n    \n    #if (ENB_MOUSE)\n    uint8_t mouse_report[4] = {0x00/*btns*/, 0/*x*/, 0/*y*/, 0/*wheel*/};\n    \n    mouse_report[1] = x;\n    ret = usbd_hid_send_report(MOUSE_IN_EP, 4, mouse_report);\n    USB_LOG_RAW(\"mouse(x:%d,ret:%d)\\r\\n\", mouse_report[1],ret);\n    #endif\n    \n    return ret;\n}",
      "file_path": "./usb\\src\\demo_hid_boot.c",
      "line_number": 320,
      "is_static": false
    },
    {
      "name": "hid_wakeup",
      "return_type": "void",
      "parameters": [
        {
          "name": "",
          "type": "void",
          "description": ""
        }
      ],
      "function_body": "{\n    if (suspend) {\n        usbd_resume(1);\n        btmr_delay(48000, 30);\n        usbd_resume(0);\n    }\n}",
      "file_path": "./usb\\src\\demo_hid_boot.c",
      "line_number": 336,
      "is_static": false
    },
    {
      "name": "usbd_hid_leds",
      "return_type": "void",
      "parameters": [
        {
          "name": "",
          "type": "uint8_t",
          "description": ""
        }
      ],
      "function_body": "{\n    if (leds & 0x02/*CAPS_LOCK*/)\n        GPIO_DAT_CLR(LED2);\n    else\n        GPIO_DAT_SET(LED2);\n}",
      "file_path": "./usb\\src\\demo_hid_boot.c",
      "line_number": 345,
      "is_static": false
    },
    {
      "name": "usbdTest",
      "return_type": "void",
      "parameters": [
        {
          "name": "",
          "type": "void",
          "description": ""
        }
      ],
      "function_body": "{\n    // keys_scan to send report\n    static uint16_t btn_lvl = BTNS;\n    uint8_t ret = 0;\n    uint16_t value = GPIO_PIN_GET() & BTNS;\n    uint16_t chng = btn_lvl ^ value;\n    btn_lvl = value;\n    \n    if (chng) {\n        uint8_t code = 0;\n        \n        hid_wakeup();\n        \n        if ((chng & BTN1) && ((value & BTN1) == 0)) {\n            code = 4;//HID_KEY_A; //code = 40;//HID_KEY_ENTER;\n        }\n        if ((chng & BTN2) && ((value & BTN2) == 0)) {\n            code = 5;//HID_KEY_B; //code = 82;//HID_KEY_UP;\n        }\n        if ((chng & BTN3) && ((value & BTN3) == 0)) {\n            code = 6;//HID_KEY_C; //code = 81;//HID_KEY_DOWN;\n        }\n        \n        debug(\"keys(val:%X,chng:%X,code:%d)\\r\\n\", btn_lvl, chng, code);\n        ret = hid_keybd_send_report(code);\n        if (ret != 0) {\n            debug(\"keys Fail(sta:%d)\\r\\n\", ret);\n        }\n        \n        if (code) {\n            GPIO_DAT_CLR(LED1);\n            hid_mouse_send_report(10);\n        }\n        else {\n            GPIO_DAT_SET(LED1);\n            hid_mouse_send_report(-10);\n        }\n    }\n}",
      "file_path": "./usb\\src\\demo_hid_boot.c",
      "line_number": 353,
      "is_static": false
    },
    {
      "name": "usbdTest",
      "return_type": "void",
      "parameters": [
        {
          "name": "",
          "type": "void",
          "description": ""
        }
      ],
      "function_body": "{\n    // circle polling to send report\n    static uint8_t keynum = 0;\n    uint8_t ret;\n    \n    if (!usbd_is_configured())\n        return;\n\n    #if (ENB_KEYBD)\n    /*!< keyboard test */\n    {\n        uint8_t kyebd_report[8] = { 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 }; //A\n        if ((keynum % 2) == 0)\n            kyebd_report[2] = HID_KEY_A + keynum/2;\n        \n        ret = usbd_hid_send_report(KEYBD_IN_EP, 8, kyebd_report);\n        USB_LOG_RAW(\"hid_keybd(key:%d,ret:%d)\\r\\n\", keynum, ret);\n    }\n    #endif\n    \n    #if (ENB_MOUSE)\n    /*!< mouse test */\n    {\n        uint8_t mouse_report[4] = {0x00/*btns*/, 0/*x*/, 0/*y*/, 0/*wheel*/};\n        if ((keynum % 2) == 0)\n            mouse_report[1] = 8;\n        else\n            mouse_report[1] = -8;\n        \n        ret = usbd_hid_send_report(MOUSE_IN_EP, 4, mouse_report);\n        USB_LOG_RAW(\"hid_mouse(x:%d,ret:%d)\\r\\n\", mouse_report[1],ret);\n    }\n    #endif\n\n    if (ret == USBD_OK) {\n        if (++keynum > 94*2) keynum = 0;\n    }\n}",
      "file_path": "./usb\\src\\demo_hid_boot.c",
      "line_number": 394,
      "is_static": false
    },
    {
      "name": "usbdInit",
      "return_type": "void",
      "parameters": [
        {
          "name": "",
          "type": "void",
          "description": ""
        }
      ],
      "function_body": "{\n    usbd_init();\n    usbd_register(hid_descriptor, hid_configuration);\n    \n    for (uint8_t idx = 0; idx < USB_HID_INTF_CNT; idx++) {\n        usbd_hid_init(idx, &hid_interface[idx]);\n    }\n    \n    keys_init();  \n}",
      "file_path": "./usb\\src\\demo_hid_boot.c",
      "line_number": 435,
      "is_static": false
    }
