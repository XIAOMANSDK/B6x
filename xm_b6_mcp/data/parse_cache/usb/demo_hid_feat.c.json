{
  "file_path": "usb/src/demo_hid_feat.c",
  "functions": [
    {
      "name": "usbd_hid_kbd_out_handler",
      "return_type": "void",
      "parameters": [
        {
          "name": "",
          "type": "uint8_t",
          "description": ""
        }
      ],
      "function_body": "{\n    uint8_t led_state;\n\n    /*!< read the led data from host send */\n    usbd_ep_read(ep, KBD_OUT_EP_SIZE, &led_state);\n    USB_LOG_RAW(\"led_state:%02X\\r\\n\", led_state);\n\n    /*!< here you can write the LED processing from the host */\n    usbd_hid_leds(led_state);\n}",
      "file_path": "usb/src/demo_hid_feat.c",
      "line_number": 311,
      "is_static": false
    },
    {
      "name": "usbd_hid_raw_out_handler",
      "return_type": "void",
      "parameters": [
        {
          "name": "",
          "type": "uint8_t",
          "description": ""
        }
      ],
      "function_body": "{\n    uint8_t custom_data[RAW_OUT_EP_SIZE];\n\n    /*!< read the data from host send */\n    usbd_ep_read(RAW_OUT_EP, RAW_OUT_EP_SIZE, custom_data);\n\n    /*!< you can use the data do some thing you like */\n}",
      "file_path": "usb/src/demo_hid_feat.c",
      "line_number": 323,
      "is_static": false
    },
    {
      "name": "usbd_notify_handler",
      "return_type": "__USBIRQ",
      "parameters": [
        {
          "name": "",
          "type": "uint8_t",
          "description": ""
        },
        {
          "name": "arg",
          "type": "void",
          "description": ""
        }
      ],
      "function_body": "{\n    switch (event) {\n        case USBD_EVENT_RESET:\n            usbd_hid_reset();\n            break;\n        case USBD_EVENT_RESUME:\n            break;\n        case USBD_EVENT_SUSPEND:\n            break;\n\n        default:\n            break;\n    }\n}",
      "file_path": "usb/src/demo_hid_feat.c",
      "line_number": 333,
      "is_static": false
    },
    {
      "name": "usbdInit",
      "return_type": "void",
      "parameters": [
        {
          "name": "",
          "type": "void",
          "description": ""
        }
      ],
      "function_body": "{\n    usbd_init();\n    usbd_register(hid_descriptor, hid_configuration);\n    #if (USBD_ADVANCE_API)\n    usbd_register_events(0xFF, usbd_notify_handler);\n    #endif\n    for (uint8_t idx = 0; idx < USB_HID_INTF_CNT; idx++) {\n        usbd_hid_init(idx, &hid_interface[idx]);\n    }\n}",
      "file_path": "usb/src/demo_hid_feat.c",
      "line_number": 355,
      "is_static": false
    },
    {
      "name": "usbdTest",
      "return_type": "void",
      "parameters": [
        {
          "name": "",
          "type": "void",
          "description": ""
        }
      ],
      "function_body": "{\n    // circle polling to send report\n    static uint8_t keynum = 0;\n\n    if (!usbd_is_configured())\n        return;\n\n    if (hid_feature)\n    {\n        hid_feature = false;\n    /*!< keyboard test */\n    {\n        uint8_t sendbuffer1[KBD_IN_EP_SIZE] = { 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 }; //A\n\n        sendbuffer1[2] = HID_KEY_A + keynum;\n        usbd_hid_send_report(KBD_IN_EP, KBD_IN_EP_SIZE, sendbuffer1);\n        /*!< delay 10ms */\n        bootDelayMs(10);\n        /*!< send button up */\n        sendbuffer1[2] = 0;\n        usbd_hid_send_report(KBD_IN_EP, KBD_IN_EP_SIZE, sendbuffer1);\n    }\n\n    /*!< delay 100ms the custom test */\n    {\n        bootDelayMs(100);\n        /*!< custom test */\n        uint8_t sendbuffer2[RAW_IN_EP_SIZE];\n\n        memset(sendbuffer2, keynum, RAW_IN_EP_SIZE);\n        usbd_hid_send_report(RAW_IN_EP, RAW_IN_EP_SIZE, sendbuffer2);\n    }\n\n    if (++keynum > 37) keynum = 0;\n    }\n}",
      "file_path": "usb/src/demo_hid_feat.c",
      "line_number": 367,
      "is_static": false
    }
