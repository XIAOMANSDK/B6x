      "function_body": "{\n    #if (ENB_MIC)\n    if (intf_num == AUDIO_AS_MIC_INTF_NUM) {\n        if (alt_setting == 1) {\n            mic_state = MIC_IDLE;\n            USB_LOG_RAW(\"Mic On\\r\\n\");\n        } else {\n            mic_state = MIC_OFF;\n            USB_LOG_RAW(\"Mic Off\\r\\n\");\n        }\n    }\n    #endif\n\n    #if (ENB_SPEAKER)\n    if (intf_num == AUDIO_AS_SPEAKER_INTF_NUM) {\n        if (alt_setting == 1) {\n            spk_state = SPK_ON;\n            USB_LOG_RAW(\"Speaker On\\r\\n\");\n        } else {\n            spk_state = SPK_OFF;\n            USB_LOG_RAW(\"Speaker Off\\r\\n\");\n        }\n    }\n    #endif\n}",
