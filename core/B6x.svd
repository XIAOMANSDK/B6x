                        </field>
                    </fields>
                </register>

                <register>
                    <name>DB</name>
                    <description>exti input debounce enable register</description>
                    <addressOffset>0x028</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>EXTI_SRC0</name>
                            <description>EXTI IO00</description>
                            <bitRange>[0:0]</bitRange>
                        </field>

                        <field>
                            <name>EXTI_SRC1</name>
                            <description>EXTI IO01</description>
                            <bitRange>[1:1]</bitRange>
                        </field>

                        <field>
                            <name>EXTI_SRC2</name>
                            <description>EXTI IO02</description>
                            <bitRange>[2:2]</bitRange>
                        </field>

                        <field>
                            <name>EXTI_SRC3</name>
                            <description>EXTI IO03</description>
                            <bitRange>[3:3]</bitRange>
                        </field>

                        <field>
                            <name>EXTI_SRC4</name>
                            <description>EXTI IO04</description>
                            <bitRange>[4:4]</bitRange>
                        </field>

                        <field>
                            <name>EXTI_SRC5</name>
                            <description>EXTI IO05</description>
                            <bitRange>[5:5]</bitRange>
                        </field>

                        <field>
                            <name>EXTI_SRC6</name>
                            <description>EXTI IO06</description>
                            <bitRange>[6:6]</bitRange>
                        </field>

                        <field>
                            <name>EXTI_SRC7</name>
                            <description>EXTI IO07</description>
                            <bitRange>[7:7]</bitRange>
                        </field>
                        <field>
                            <name>EXTI_SRC8</name>
                            <description>EXTI IO08</description>
                            <bitRange>[8:8]</bitRange>
                        </field>

                        <field>
                            <name>EXTI_SRC9</name>
                            <description>EXTI IO09</description>
                            <bitRange>[9:9]</bitRange>
                        </field>

                        <field>
                            <name>EXTI_SRC10</name>
                            <description>EXTI IO10</description>
                            <bitRange>[10:10]</bitRange>
                        </field>

                        <field>
                            <name>EXTI_SRC11</name>
                            <description>EXTI IO11</description>
                            <bitRange>[11:11]</bitRange>
                        </field>
                        <field>
                            <name>EXTI_SRC12</name>
                            <description>EXTI IO12</description>
                            <bitRange>[12:12]</bitRange>
                        </field>

                        <field>
                            <name>EXTI_SRC13</name>
                            <description>EXTI IO13</description>
