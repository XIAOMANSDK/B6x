                </register>

                <register>
                    <name>EXT_ST</name>
                    <description>EXT_ST register</description>
                    <addressOffset>0x038</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>MDM_TX_DONE</name>
                            <description>1:TX fifo is empty and last bit is sent out, cleared when tx_en is 0</description>
                            <bitRange>[0:0]</bitRange>
                        </field>

                        <field>
                            <name>MDM_SYNC_ERR</name>
                            <description>when RX sync over time, mdm_sync_err is 1, cleared by rx_en is 0</description>
                            <bitRange>[1:1]</bitRange>
                        </field>

                        <field>
                            <name>MDM_SLOT_INT</name>
                            <description>cleared by mdm_slot_int_clr</description>
                            <bitRange>[2:2]</bitRange>
                        </field>

                        <field>
                            <name>MDM_SLOT_OVER</name>
                            <description>cleared by mdm_slot_int_clr</description>
                            <bitRange>[3:3]</bitRange>
                        </field>

                        <field>
                            <name>MDM_SYNC_FOUND</name>
                            <description>cleared by rx_en is 0</description>
                            <bitRange>[4:4]</bitRange>
                        </field>

                        <field>
                            <name>FIFO_EMPTY</name>
                            <description>FIFO_EMPTY</description>
                            <bitRange>[5:5]</bitRange>
                        </field>

                        <field>
                            <name>FIFO_FULL</name>
                            <description>FIFO_FULL</description>
                            <bitRange>[6:6]</bitRange>
                        </field>

                        <field>
                            <name>FIFO_NUM</name>
                            <description>FIFO_NUM</description>
                            <bitRange>[9:7]</bitRange>
                        </field>

                        <field>
                            <name>MDM_SYNC_TIME</name>
                            <description>only valid when mdm_sync_found is 1, cleared when rx_en is 0</description>
                            <bitRange>[21:10]</bitRange>
                        </field>
                    </fields>
                </register>
            </registers>
        </peripheral>

        <!--RF Reg OK-->
        <peripheral>
            <name>RF</name>
            <description>Radio Freq</description>
            <baseAddress>0x4002C000</baseAddress>
            <addressBlock>
                <offset>0x000</offset>
                <size>0x078</size>
                <usage>registers</usage>
            </addressBlock>
            <interrupt>
                <name>RF</name>
                <value>21</value>
            </interrupt>
            <registers>
                <register>
                    <name>DIG_CTRL</name>
                    <description>DIG_CTRL register</description>
                    <addressOffset>0x000</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>ANA_TEST_EN</name>
                            <description>ANA_TEST_EN Enable or Disable</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>RF ANALOG digital input is controlled by reg</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>RF ANALOG digital input is controlled by rfdig_gsm</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>LDO_TEST_EN</name>
                            <description>LDO_TEST_EN Enable or Disable</description>
                            <lsb>1</lsb>
                            <msb>1</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>analog block power is controlled by reg</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>analog block power is controlled by RF Dig FSM</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_CAL_TEST_EN</name>
                            <description>PLL_CAL_TEST_EN Enable or Disable</description>
                            <lsb>2</lsb>
                            <msb>2</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>PLL AFC and GAIN CAL directed controlled by reg</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>PLL AFC and GAIN CAL controlled by rf_pll_cal module</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>FSM_CTRL_SEL</name>
                            <description>FSM_CTRL_SEL Enable or Disable</description>
                            <lsb>3</lsb>
                            <msb>3</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>RF Dig FSM input signal is from rf_reg</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>RF Dig FSM input signal is from BB </description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PA_GAIN_TARGET_SEL</name>
                            <description>PA_GAIN_TARGET_SEL Enable or Disable</description>
                            <lsb>4</lsb>
                            <msb>4</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>the pa_gain_target is from sw_pa_gain_target</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>the pa_gain_target is from BB</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_AFC_BY</name>
                            <description>PLL_AFC_BY Enable or Disable</description>
                            <lsb>5</lsb>
                            <msb>5</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>rfdig FSM bypass AFC calib, AFC calib can be start by software</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>rfdig FSM start AFC calib</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_BPF_CAL_BY</name>
                            <description>PLL_BPF_CAL_BY Enable or Disable</description>
                            <lsb>6</lsb>
                            <msb>6</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>rfdig FSM bypass AFC calib, AFC calib can be start by software</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>rfdig FSM start BPF calib</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_FREQ_SEL</name>
                            <description>PLL_FREQ_SEL Enable or Disable</description>
                            <lsb>7</lsb>
                            <msb>7</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>PLL frequency is controlled by reg sw_di_s and sw_frac</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>PLL frequency is controlled by channel number</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_FREQ_EXT_EN</name>
                            <description>PLL_FREQ_EXT_EN Enable or Disable</description>
                            <lsb>8</lsb>
                            <msb>8</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>PLL_FREQ_ADJ[5:0] is driven by PLL_FREQ_EXT</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>PLL_FREQ_ADJ[5:0] is driven by AFC Calib logic </description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_GAIN_CAL_BY</name>
                            <description>PLL_GAIN_CAL_BY Enable or Disable</description>
                            <lsb>9</lsb>
                            <msb>9</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>rfdig FSM bypass PLL GAIN calib, PLL GAIN calib can be start by software</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>rfdig FSM start PLL GAIN calib</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_VTXD_EXT_EN</name>
                            <description>PLL_VTXD_EXT_EN Enable or Disable</description>
                            <lsb>10</lsb>
                            <msb>10</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>PLL_DAC_ADJ[4:0] is driven by PLL_VTXD_EXT</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>PLL_DAC_ADJ[4:0] is driven by GAIN Calib logic </description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_GAIN_CAL_STEP</name>
                            <description>PLL_GAIN_CAL_STEP Enable or Disable</description>
                            <lsb>11</lsb>
                            <msb>11</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>MCU step by step debug PLL GAIN CAL, only effect when pll_gain_cal_by is 1</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>rfdig FSM PLL GAIN CAL</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_GAIN_CAL_TAB</name>
                            <description>active when pll_gain_cal_by is 1 and pll_vtxd_ext_en is 0 and pll_gain_cal_step is 0</description>
                            <lsb>12</lsb>
                            <msb>12</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>PLL_DAC_ADJ[4:0] is driven by lookup table</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>PLL_DAC_ADJ[4:0] is driven by lookup table</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_GAIN_CAL_MODE</name>
                            <description>active when pll_gain_cal_by is 1 and pll_vtxd_ext_en is 0 and pll_gain_cal_step is 0</description>
                            <bitRange>[14:13]</bitRange>
                        </field>

                        <field>
                            <name>PLL_AFC_ROUND</name>
                            <description>PLL_AFC_ROUND Enable or Disable</description>
                            <bitRange>[15:15]</bitRange>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>rfdig FSM bypass AFC calib, AFC calib can be start by software</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>floor result</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_AFC_STEP</name>
                            <description>PLL_AFC_STEP Enable or Disable, only effect when pll_afc_by is 1</description>
                            <bitRange>[16:16]</bitRange>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>MCU step by step debug PLL AFC</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>rfdig FSM step debug PLL AFC</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_FREQ_DC</name>
                            <description>DC offset used for AFC calib done</description>
                            <bitRange>[19:17]</bitRange>
                        </field>

                        <field>
                            <name>PLL_AFC_MODE</name>
                            <description>PLL_AFC_MODE Enable or Disable</description>
                            <bitRange>[20:20]</bitRange>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>don't set hbw_en as 1 when AFC is done, makesure pll_gain_cal_by is 0</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>set hbw_en as 1 when AFC is done</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PLL_AFC_FRAC_EN</name>
                            <description>PLL_AFC_FRAC_EN Enable or Disable</description>
                            <bitRange>[21:21]</bitRange>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>use PLL_FRAC[23]</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>rfdig FSM control</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>SW_PLL_CAL_CLKEN</name>
                            <description>SW_PLL_CAL_CLKEN Enable or Disable</description>
                            <bitRange>[22:22]</bitRange>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>enable PLL AFC and GAIN CAL clock by MCU, set as 1 when pll_afc_by or pll_gain_cal_by is 1</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>rfdig FSM control</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>SW_AFC_EN</name>
                            <description>SW_AFC_EN Enable or Disable</description>
                            <bitRange>[23:23]</bitRange>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>PLL AFC Calibration start work, only effect when pll_afc_by is 1</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>rfdig FSM control</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>SW_GAIN_CAL_EN</name>
                            <description>SW_GAIN_CAL_EN Enable or Disable</description>
                            <bitRange>[24:24]</bitRange>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>PLL GAIN Calibration start work, only effect when pll_gain_cal_by is 1</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>rfdig FSM control</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>SW_PLL_VREF_SEL</name>
                            <description>SW_PLL_VREF_SEL Enable or Disable</description>
                            <bitRange>[25:25]</bitRange>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>use to control DAC_VREF_SEL when pll_gain_cal_step is 1 or used when pll_cal_test_en is 1</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>rfdig FSM control</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>SW_PLL_HBW_EN</name>
                            <description>SW_PLL_HBW_EN Enable or Disable</description>
                            <bitRange>[26:26]</bitRange>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>software set PLL is in HBW_EN as 1</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>HBW_EN is driven by pll_cal logic</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>SDM_FRAC_INT_MODE</name>
                            <description>SDM_FRAC_INT_MODE Enable or Disable</description>
                            <bitRange>[27:27]</bitRange>
                        </field>

                        <field>
                            <name>PLL_CAL_ERR_CLR</name>
                            <description>PLL_CAL_ERR_CLR</description>
                            <bitRange>[28:28]</bitRange>
                        </field>

                        <field>
                            <name>CAL_ERR_INT_EN</name>
                            <description>CAL_ERR_INT_EN</description>
                            <bitRange>[29:29]</bitRange>
                        </field>

                        <field>
                            <name>RF_DBG_SEL</name>
                            <description>1---tx, 2---rx</description>
                            <bitRange>[31:30]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>PLL_TAB_OFFSET</name>
                    <description>PLL_TAB_OFFSET register</description>
                    <addressOffset>0x004</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>TX_FRAC_OFFSET</name>
                            <description>signed data, unit : 1MHz/1024, near as 1KHz, arrange: -512KHz ~ 511 KHz</description>
                            <bitRange>[9:0]</bitRange>
                        </field>

                        <field>
                            <name>RX_FRAC_OFFSET</name>
                            <description>signed data, unit : 1MHz/1024, near as 1KHz, arrange: -512KHz ~ 511 KHz</description>
                            <bitRange>[19:10]</bitRange>
                        </field>

                        <field>
                            <name>PLL_FREQ_EXT</name>
                            <description>used when pll_freq_ext_en or pll_afc_step is 1</description>
                            <bitRange>[25:20]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>PLL_GAIN_CTRL</name>
                    <description>PLL_GAIN_CTRL register</description>
                    <addressOffset>0x008</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>PLL_VTXD_EXT</name>
                            <description>used when pll_vtxd_ext_en or pll_gain_cal_step is 1</description>
                            <bitRange>[5:0]</bitRange>
                        </field>

                        <field>
                            <name>PLL_GAIN_CAL_DC</name>
                            <description>DC offset used for GAIN CAL calib done, signed data: -4 ~ 3</description>
                            <bitRange>[8:6]</bitRange>
                        </field>

                        <field>
                            <name>PLL_GAIN_CAL_WIN</name>
                            <description>PLL GAIN CAL step window, step window time : (pll_gain_cal_win + 1)  us</description>
                            <bitRange>[14:9]</bitRange>
                        </field>

                        <field>
                            <name>PLL_GAIN_CAL_TH</name>
                            <description>df1 : 250K * 80 = 40M, pll_gain_cal_th : 40 * (GAIN CAL step window)</description>
                            <bitRange>[26:15]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>RSSI_CTRL</name>
                    <description>RSSI_CTRL register</description>
                    <addressOffset>0x00C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>RSSI_VAL</name>
                            <description>RSSI_VAL</description>
                            <lsb>0</lsb>
                            <msb>7</msb>
                        </field>

                        <field>
                            <name>AGC_LNA_GAIN</name>
                            <description>AGC_LNA_GAIN</description>
                            <lsb>8</lsb>
                            <msb>11</msb>
                        </field>

                        <field>
                            <name>AGC_BPF_GAIN_ADJ</name>
                            <description>AGC_BPF_GAIN_ADJ</description>
                            <lsb>12</lsb>
                            <msb>13</msb>
                        </field>

                        <field>
                            <name>AGC_MIXL_GAIN_CTL</name>
                            <description>AGC_MIXL_GAIN_CTL</description>
                            <lsb>14</lsb>
                            <msb>14</msb>
                        </field>

                        <field>
                            <name>AGC_MIXH_GAIN_CTL</name>
                            <description>AGC_MIXH_GAIN_CTL</description>
                            <lsb>15</lsb>
                            <msb>15</msb>
                        </field>

                        <field>
                            <name>SW_RSSI_READY</name>
                            <description>SW_RSSI_READY</description>
                            <lsb>16</lsb>
                            <msb>16</msb>
                        </field>

                        <field>
                            <name>SW_RSSI_REQ</name>
                            <description>SW_RSSI_REQ</description>
                            <lsb>17</lsb>
                            <msb>17</msb>
                        </field>

                        <field>
                            <name>RF_FSM_STATE</name>
                            <description>RF_FSM_STATE</description>
                            <lsb>18</lsb>
                            <msb>22</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>PLL_DAC_TAB0</name>
                    <description>PLL_DAC_TAB0 register</description>
                    <addressOffset>0x010</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>PLL_DAC_ADJ00</name>
                            <description>PLL_DAC_ADJ00</description>
                            <bitRange>[5:0]</bitRange>
                        </field>

                        <field>
                            <name>PLL_DAC_ADJ01</name>
                            <description>PLL_DAC_ADJ01</description>
                            <bitRange>[11:6]</bitRange>
                        </field>

                        <field>
                            <name>PLL_DAC_ADJ02</name>
                            <description>PLL_DAC_ADJ02</description>
                            <bitRange>[17:12]</bitRange>
                        </field>

                        <field>
                            <name>PLL_DAC_ADJ03</name>
                            <description>PLL_DAC_ADJ03</description>
                            <bitRange>[23:18]</bitRange>
                        </field>

                        <field>
