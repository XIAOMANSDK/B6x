                <register>
                    <name>DBC</name>
                    <description>exti input debounce sample rate control register</description>
                    <addressOffset>0x02C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>DB_CNT</name>
                            <description>debounce cnts,  db_cnt = db_cnt_val + 1</description>
                            <bitRange>[2:0]</bitRange>
                        </field>

                        <field>
                            <name>DB_PRE</name>
                            <description>debounce one cnt include current clk cycles, db_pre = db_pre_val + 1</description>
                            <bitRange>[15:8]</bitRange>
                        </field>
                    </fields>
                </register>
            </registers>
        </peripheral>

        <!--CTMR: General Purpose Timer-->
        <peripheral>
            <name>CTMR</name>
            <description>General Purpose Timer</description>
            <baseAddress>0x40021000</baseAddress>
            <addressBlock>
                <offset>0</offset>
                <size>0x5C</size>
                <usage>registers</usage>
            </addressBlock>
            <interrupt>
                <name>CTMR</name>
                <value>6</value>
            </interrupt>
            <registers>
                <register>
                    <name>CR1</name>
                    <description>Control register 1</description>
                    <addressOffset>0x000</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>CEN</name><description>Counter Enable</description><bitRange>[0:0]</bitRange></field>
                        <field><name>UDIS</name><description>Update Disable</description><bitRange>[1:1]</bitRange></field>
                        <field><name>URS</name><description>Update Request Source</description><bitRange>[2:2]</bitRange></field>
                        <field><name>OPM</name><description>One Pulse Mode</description><bitRange>[3:3]</bitRange></field>
                        <field><name>DIR</name><description>Direction</description><bitRange>[4:4]</bitRange></field>
                        <field><name>CMS</name><description>Center-aligned Mode Select</description><bitRange>[6:5]</bitRange></field>
                        <field><name>ARPE</name><description>Auto-Reload Preload Enable</description><bitRange>[7:7]</bitRange></field>
                        <field><name>CKD</name><description>Clock Division</description><bitRange>[9:8]</bitRange></field>
                        <field><name>CMPSEL</name><description>Compare input Select (Only ATMR)</description><bitRange>[11:10]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>CR2</name>
                    <description>Control register 2</description>
                    <addressOffset>0x004</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>CCPC</name><description>Capture/Compare Preload Control (Only ATMR)</description><bitRange>[0:0]</bitRange></field>
                        <field><name>CCUS</name><description>Capture/Compare Control Update Select (Only ATMR)</description><bitRange>[2:2]</bitRange></field>
                        <field><name>CCDS</name><description>Capture/Compare DMA Select</description><bitRange>[3:3]</bitRange></field>
                        <field><name>MMS</name><description>Master Mode Select</description><bitRange>[6:4]</bitRange></field>
                        <field><name>TI1S</name><description>TI1 Select</description><bitRange>[7:7]</bitRange></field>
                        <field><name>OIS1</name><description>Output Idle State1 (OC1 Output) (Only ATMR)</description><bitRange>[8:8]</bitRange></field>
                        <field><name>OIS1N</name><description>Output Idle State1 (OC1N Output) (Only ATMR)</description><bitRange>[9:9]</bitRange></field>
                        <field><name>OIS2</name><description>Output Idle State2 (OC2 Output) (Only ATMR)</description><bitRange>[10:10]</bitRange></field>
                        <field><name>OIS2N</name><description>Output Idle State2 (OC2N Output) (Only ATMR)</description><bitRange>[11:11]</bitRange></field>
                        <field><name>OIS3</name><description>Output Idle State3 (OC3 Output) (Only ATMR)</description><bitRange>[12:12]</bitRange></field>
                        <field><name>OIS3N</name><description>Output Idle State3 (OC3N Output) (Only ATMR)</description><bitRange>[13:13]</bitRange></field>
                        <field><name>OIS4</name><description>Output Idle State4 (OC4 Output) (Only ATMR)</description><bitRange>[14:14]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>SMCR</name>
                    <description>Slave mode control register</description>
                    <addressOffset>0x008</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>SMS</name><description>Slave Mode Select</description><bitRange>[2:0]</bitRange>
                            <enumeratedValues>
                                <enumeratedValue><name>Disabled</name><description>Slave mode disabled</description><value>0</value></enumeratedValue>
                                <enumeratedValue><name>Reset_Mode</name><description>Rising edge of TRGI reinitializes counter</description><value>4</value></enumeratedValue>
                                <enumeratedValue><name>Gated_Mode</name><description>Counter clock enabled when TRGI is high</description><value>5</value></enumeratedValue>
                                <enumeratedValue><name>Trigger_Mode</name><description>Counter starts at rising edge of TRGI</description><value>6</value></enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field><name>TS</name><description>Trigger Select</description><bitRange>[6:4]</bitRange></field>
                        <field><name>MSM</name><description>Master/Slave Mode</description><bitRange>[7:7]</bitRange></field>
                        <field><name>ETF</name><description>External Trigger Filter</description><bitRange>[11:8]</bitRange></field>
                        <field><name>ETPS</name><description>External Trigger Prescaler</description><bitRange>[13:12]</bitRange></field>
                        <field><name>ETE</name><description>External Clock Enable</description><bitRange>[14:14]</bitRange></field>
                        <field><name>ETP</name><description>External Trigger Polarity</description><bitRange>[15:15]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>IER</name>
                    <description>Interrupt Enable register</description>
                    <addressOffset>0x00C</addressOffset>
                    <access>write-only</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>UI</name><description>Update Interrupt</description><bitRange>[0:0]</bitRange></field>
                        <field><name>CC1I</name><description>Capture/Compare 1 Interrupt</description><bitRange>[1:1]</bitRange></field>
                        <field><name>CC2I</name><description>Capture/Compare 2 Interrupt</description><bitRange>[2:2]</bitRange></field>
                        <field><name>CC3I</name><description>Capture/Compare 3 Interrupt</description><bitRange>[3:3]</bitRange></field>
                        <field><name>CC4I</name><description>Capture/Compare 4 Interrupt</description><bitRange>[4:4]</bitRange></field>
                        <field><name>COMI</name><description>COM Interrupt (Only ATMR)</description><bitRange>[5:5]</bitRange></field>
                        <field><name>TI</name><description>Trigger Interrupt</description><bitRange>[6:6]</bitRange></field>
                        <field><name>BI</name><description>Break Interrupt (Only ATMR)</description><bitRange>[7:7]</bitRange></field>
                        <field><name>CC1OI</name><description>Capture/Compare 1 Overcapture Interrupt</description><bitRange>[9:9]</bitRange></field>
                        <field><name>CC2OI</name><description>Capture/Compare 2 Overcapture Interrupt</description><bitRange>[10:10]</bitRange></field>
                        <field><name>CC3OI</name><description>Capture/Compare 3 Overcapture Interrupt</description><bitRange>[11:11]</bitRange></field>
                        <field><name>CC4OI</name><description>Capture/Compare 4 Overcapture Interrupt</description><bitRange>[12:12]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>IDR</name>
                    <description>Interrupt Disable register</description>
                    <addressOffset>0x010</addressOffset>
                    <access>write-only</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>UI</name><description>Update Interrupt</description><bitRange>[0:0]</bitRange></field>
                        <field><name>CC1I</name><description>Capture/Compare 1 Interrupt</description><bitRange>[1:1]</bitRange></field>
                        <field><name>CC2I</name><description>Capture/Compare 2 Interrupt</description><bitRange>[2:2]</bitRange></field>
                        <field><name>CC3I</name><description>Capture/Compare 3 Interrupt</description><bitRange>[3:3]</bitRange></field>
                        <field><name>CC4I</name><description>Capture/Compare 4 Interrupt</description><bitRange>[4:4]</bitRange></field>
                        <field><name>COMI</name><description>COM Interrupt (Only ATMR)</description><bitRange>[5:5]</bitRange></field>
                        <field><name>TI</name><description>Trigger Interrupt</description><bitRange>[6:6]</bitRange></field>
                        <field><name>BI</name><description>Break Interrupt (Only ATMR)</description><bitRange>[7:7]</bitRange></field>
                        <field><name>CC1OI</name><description>Capture/Compare 1 Overcapture Interrupt</description><bitRange>[9:9]</bitRange></field>
                        <field><name>CC2OI</name><description>Capture/Compare 2 Overcapture Interrupt</description><bitRange>[10:10]</bitRange></field>
                        <field><name>CC3OI</name><description>Capture/Compare 3 Overcapture Interrupt</description><bitRange>[11:11]</bitRange></field>
                        <field><name>CC4OI</name><description>Capture/Compare 4 Overcapture Interrupt</description><bitRange>[12:12]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>IVS</name>
                    <description>Interrupt Valid status register</description>
                    <addressOffset>0x014</addressOffset>
                    <access>read-only</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>UI</name><description>Update Interrupt Valid Status</description><bitRange>[0:0]</bitRange></field>
                        <field><name>CC1I</name><description>Capture/Compare 1 Interrupt Valid Status</description><bitRange>[1:1]</bitRange></field>
                        <field><name>CC2I</name><description>Capture/Compare 2 Interrupt Valid Status</description><bitRange>[2:2]</bitRange></field>
                        <field><name>CC3I</name><description>Capture/Compare 3 Interrupt Valid Status</description><bitRange>[3:3]</bitRange></field>
                        <field><name>CC4I</name><description>Capture/Compare 4 Interrupt Valid Status</description><bitRange>[4:4]</bitRange></field>
                        <field><name>COMI</name><description>COM Interrupt Valid Status (Only ATMR)</description><bitRange>[5:5]</bitRange></field>
                        <field><name>TI</name><description>Trigger Interrupt Valid Status</description><bitRange>[6:6]</bitRange></field>
                        <field><name>BI</name><description>Break Interrupt Valid Status (Only ATMR)</description><bitRange>[7:7]</bitRange></field>
                        <field><name>CC1OI</name><description>Capture/Compare 1 Overcapture Interrupt Valid Status</description><bitRange>[9:9]</bitRange></field>
                        <field><name>CC2OI</name><description>Capture/Compare 2 Overcapture Interrupt Valid Status</description><bitRange>[10:10]</bitRange></field>
                        <field><name>CC3OI</name><description>Capture/Compare 3 Overcapture Interrupt Valid Status</description><bitRange>[11:11]</bitRange></field>
                        <field><name>CC4OI</name><description>Capture/Compare 4 Overcapture Interrupt Valid Status</description><bitRange>[12:12]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>RIF</name>
                    <description>Raw interrupt Flag</description>
                    <addressOffset>0x018</addressOffset>
                    <access>read-only</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>UI</name><description>Update Raw Interrupt Flag</description><bitRange>[0:0]</bitRange></field>
                        <field><name>CC1I</name><description>Capture/Compare 1 Raw Interrupt Flag</description><bitRange>[1:1]</bitRange></field>
                        <field><name>CC2I</name><description>Capture/Compare 2 Raw Interrupt Flag</description><bitRange>[2:2]</bitRange></field>
                        <field><name>CC3I</name><description>Capture/Compare 3 Raw Interrupt Flag</description><bitRange>[3:3]</bitRange></field>
                        <field><name>CC4I</name><description>Capture/Compare 4 Raw Interrupt Flag</description><bitRange>[4:4]</bitRange></field>
                        <field><name>COMI</name><description>COM Raw Interrupt Flag (Only ATMR)</description><bitRange>[5:5]</bitRange></field>
                        <field><name>TI</name><description>Trigger Raw Interrupt Flag</description><bitRange>[6:6]</bitRange></field>
                        <field><name>BI</name><description>Break Raw Interrupt Flag (Only ATMR)</description><bitRange>[7:7]</bitRange></field>
                        <field><name>CC1OI</name><description>Capture/Compare 1 Overcapture Raw Interrupt Flag</description><bitRange>[9:9]</bitRange></field>
                        <field><name>CC2OI</name><description>Capture/Compare 2 Overcapture Raw Interrupt Flag</description><bitRange>[10:10]</bitRange></field>
                        <field><name>CC3OI</name><description>Capture/Compare 3 Overcapture Raw Interrupt Flag</description><bitRange>[11:11]</bitRange></field>
                        <field><name>CC4OI</name><description>Capture/Compare 4 Overcapture Raw Interrupt Flag</description><bitRange>[12:12]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>IFM</name>
                    <description>Masked interrupt Flag</description>
                    <addressOffset>0x01C</addressOffset>
                    <access>read-only</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>UI</name><description>Update Masked Interrupt Flag</description><bitRange>[0:0]</bitRange></field>
                        <field><name>CC1I</name><description>Capture/Compare 1 Masked Interrupt Flag</description><bitRange>[1:1]</bitRange></field>
                        <field><name>CC2I</name><description>Capture/Compare 2 Masked Interrupt Flag</description><bitRange>[2:2]</bitRange></field>
                        <field><name>CC3I</name><description>Capture/Compare 3 Masked Interrupt Flag</description><bitRange>[3:3]</bitRange></field>
                        <field><name>CC4I</name><description>Capture/Compare 4 Masked Interrupt Flag</description><bitRange>[4:4]</bitRange></field>
                        <field><name>COMI</name><description>COM Masked Interrupt Flag (Only ATMR)</description><bitRange>[5:5]</bitRange></field>
                        <field><name>TI</name><description>Trigger Masked Interrupt Flag</description><bitRange>[6:6]</bitRange></field>
                        <field><name>BI</name><description>Break Masked Interrupt Flag (Only ATMR)</description><bitRange>[7:7]</bitRange></field>
                        <field><name>CC1OI</name><description>Capture/Compare 1 Overcapture Masked Interrupt Flag</description><bitRange>[9:9]</bitRange></field>
                        <field><name>CC2OI</name><description>Capture/Compare 2 Overcapture Masked Interrupt Flag</description><bitRange>[10:10]</bitRange></field>
                        <field><name>CC3OI</name><description>Capture/Compare 3 Overcapture Masked Interrupt Flag</description><bitRange>[11:11]</bitRange></field>
                        <field><name>CC4OI</name><description>Capture/Compare 4 Overcapture Masked Interrupt Flag</description><bitRange>[12:12]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>ICR</name>
                    <description>Interrupt Clear status register</description>
                    <addressOffset>0x020</addressOffset>
                    <access>write-only</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>UI</name><description>Update Interrupt Clear</description><bitRange>[0:0]</bitRange></field>
                        <field><name>CC1I</name><description>Capture/Compare 1 Interrupt Clear</description><bitRange>[1:1]</bitRange></field>
                        <field><name>CC2I</name><description>Capture/Compare 2 Interrupt Clear</description><bitRange>[2:2]</bitRange></field>
                        <field><name>CC3I</name><description>Capture/Compare 3 Interrupt Clear</description><bitRange>[3:3]</bitRange></field>
                        <field><name>CC4I</name><description>Capture/Compare 4 Interrupt Clear</description><bitRange>[4:4]</bitRange></field>
                        <field><name>COMI</name><description>COM Interrupt Clear (Only ATMR)</description><bitRange>[5:5]</bitRange></field>
                        <field><name>TI</name><description>Trigger Interrupt Clear</description><bitRange>[6:6]</bitRange></field>
                        <field><name>BI</name><description>Break Interrupt Clear (Only ATMR)</description><bitRange>[7:7]</bitRange></field>
                        <field><name>CC1OI</name><description>Capture/Compare 1 Overcapture Interrupt Clear</description><bitRange>[9:9]</bitRange></field>
                        <field><name>CC2OI</name><description>Capture/Compare 2 Overcapture Interrupt Clear</description><bitRange>[10:10]</bitRange></field>
                        <field><name>CC3OI</name><description>Capture/Compare 3 Overcapture Interrupt Clear</description><bitRange>[11:11]</bitRange></field>
                        <field><name>CC4OI</name><description>Capture/Compare 4 Overcapture Interrupt Clear</description><bitRange>[12:12]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>EGR</name>
                    <description>Event generation register</description>
                    <addressOffset>0x024</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>UG</name><description>Update Generation</description><bitRange>[0:0]</bitRange></field>
                        <field><name>CC1G</name><description>Capture/Compare 1 Generation</description><bitRange>[1:1]</bitRange></field>
                        <field><name>CC2G</name><description>Capture/Compare 2 Generation</description><bitRange>[2:2]</bitRange></field>
                        <field><name>CC3G</name><description>Capture/Compare 3 Generation</description><bitRange>[3:3]</bitRange></field>
                        <field><name>CC4G</name><description>Capture/Compare 4 Generation</description><bitRange>[4:4]</bitRange></field>
                        <field><name>COMG</name><description>Capture/Compare Control Update Generation (Only ATMR)</description><bitRange>[5:5]</bitRange></field>
                        <field><name>TG</name><description>Trigger Generation</description><bitRange>[6:6]</bitRange></field>
                        <field><name>BG</name><description>Break Generation (Only ATMR)</description><bitRange>[7:7]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>CCMR1_Output</name>
                    <description>Capture/compare mode register 1 (Output mode)</description>
                    <addressOffset>0x028</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>CC1S</name><description>Capture/Compare 1 Select</description><bitRange>[1:0]</bitRange></field>
                        <field><name>OC1FE</name><description>Output Compare 1 Fast Enable</description><bitRange>[2:2]</bitRange></field>
                        <field><name>OC1PE</name><description>Output Compare 1 Preload Enable</description><bitRange>[3:3]</bitRange></field>
                        <field>
                            <name>OC1M</name><description>Output Compare 1 Mode</description><bitRange>[6:4]</bitRange>
                            <enumeratedValues>
                                <enumeratedValue><name>Frozen</name><description>Frozen</description><value>0</value></enumeratedValue>
                                <enumeratedValue><name>Active_on_match</name><description>Set channel to active level on match</description><value>1</value></enumeratedValue>
                                <enumeratedValue><name>Inactive_on_match</name><description>Set channel to inactive level on match</description><value>2</value></enumeratedValue>
                                <enumeratedValue><name>Toggle</name><description>Toggle</description><value>3</value></enumeratedValue>
                                <enumeratedValue><name>Force_inactive</name><description>Force inactive level</description><value>4</value></enumeratedValue>
                                <enumeratedValue><name>Force_active</name><description>Force active level</description><value>5</value></enumeratedValue>
                                <enumeratedValue><name>PWM_mode1</name><description>PWM mode 1</description><value>6</value></enumeratedValue>
                                <enumeratedValue><name>PWM_mode2</name><description>PWM mode 2</description><value>7</value></enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field><name>OC1CE</name><description>Output Compare 1 Clear Enable</description><bitRange>[7:7]</bitRange></field>
                        <field><name>CC2S</name><description>Capture/Compare 2 Select</description><bitRange>[9:8]</bitRange></field>
                        <field><name>OC2FE</name><description>Output Compare 2 Fast Enable</description><bitRange>[10:10]</bitRange></field>
                        <field><name>OC2PE</name><description>Output Compare 2 Preload Enable</description><bitRange>[11:11]</bitRange></field>
                        <field><name>OC2M</name><description>Output Compare 2 Mode</description><bitRange>[14:12]</bitRange></field>
                        <field><name>OC2CE</name><description>Output Compare 2 Clear Enable</description><bitRange>[15:15]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>CCMR1_Input</name>
                    <description>Capture/compare mode register 1 (Input mode)</description>
                    <alternateRegister>CCMR1_Output</alternateRegister>
                    <addressOffset>0x028</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>CC1S</name><description>Capture/Compare 1 Select</description><bitRange>[1:0]</bitRange></field>
                        <field><name>IC1PSC</name><description>Input Capture 1 Prescaler</description><bitRange>[3:2]</bitRange></field>
                        <field><name>IC1F</name><description>Input Capture 1 Filter</description><bitRange>[7:4]</bitRange></field>
                        <field><name>CC2S</name><description>Capture/Compare 2 Select</description><bitRange>[9:8]</bitRange></field>
                        <field><name>IC2PSC</name><description>Input Capture 2 Prescaler</description><bitRange>[11:10]</bitRange></field>
                        <field><name>IC2F</name><description>Input Capture 2 Filter</description><bitRange>[15:12]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>CCMR2_Output</name>
                    <description>Capture/compare mode register 2 (Output mode)</description>
                    <addressOffset>0x02C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>CC3S</name><description>Capture/Compare 3 Select</description><bitRange>[1:0]</bitRange></field>
                        <field><name>OC3FE</name><description>Output Compare 3 Fast Enable</description><bitRange>[2:2]</bitRange></field>
                        <field><name>OC3PE</name><description>Output Compare 3 Preload Enable</description><bitRange>[3:3]</bitRange></field>
                        <field><name>OC3M</name><description>Output Compare 3 Mode</description><bitRange>[6:4]</bitRange></field>
                        <field><name>OC3CE</name><description>Output Compare 3 Clear Enable</description><bitRange>[7:7]</bitRange></field>
                        <field><name>CC4S</name><description>Capture/Compare 4 Select</description><bitRange>[9:8]</bitRange></field>
                        <field><name>OC4FE</name><description>Output Compare 4 Fast Enable</description><bitRange>[10:10]</bitRange></field>
                        <field><name>OC4PE</name><description>Output Compare 4 Preload Enable</description><bitRange>[11:11]</bitRange></field>
                        <field><name>OC4M</name><description>Output Compare 4 Mode</description><bitRange>[14:12]</bitRange></field>
                        <field><name>OC4CE</name><description>Output Compare 4 Clear Enable</description><bitRange>[15:15]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>CCMR2_Input</name>
                    <description>Capture/compare mode register 2 (Input mode)</description>
                    <alternateRegister>CCMR2_Output</alternateRegister>
                    <addressOffset>0x02C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>CC3S</name><description>Capture/Compare 3 Select</description><bitRange>[1:0]</bitRange></field>
                        <field><name>IC3PSC</name><description>Input Capture 3 Prescaler</description><bitRange>[3:2]</bitRange></field>
                        <field><name>IC3F</name><description>Input Capture 3 Filter</description><bitRange>[7:4]</bitRange></field>
                        <field><name>CC4S</name><description>Capture/Compare 4 Select</description><bitRange>[9:8]</bitRange></field>
                        <field><name>IC4PSC</name><description>Input Capture 4 Prescaler</description><bitRange>[11:10]</bitRange></field>
                        <field><name>IC4F</name><description>Input Capture 4 Filter</description><bitRange>[15:12]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>CCER</name>
                    <description>Capture/compare enable register</description>
                    <addressOffset>0x030</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>CC1E</name><description>Capture/Compare 1 Output Enable</description><bitRange>[0:0]</bitRange></field>
                        <field><name>CC1P</name><description>Capture/Compare 1 Output Polarity</description><bitRange>[1:1]</bitRange></field>
                        <field><name>CC1NE</name><description>Capture/Compare 1 Complementary Output Enable (Only ATMR)</description><bitRange>[2:2]</bitRange></field>
                        <field><name>CC1NP</name><description>Capture/Compare 1 Complementary Output Polarity (Only ATMR)</description><bitRange>[3:3]</bitRange></field>
                        <field><name>CC2E</name><description>Capture/Compare 2 Output Enable</description><bitRange>[4:4]</bitRange></field>
                        <field><name>CC2P</name><description>Capture/Compare 2 Output Polarity</description><bitRange>[5:5]</bitRange></field>
                        <field><name>CC2NE</name><description>Capture/Compare 2 Complementary Output Enable (Only ATMR)</description><bitRange>[6:6]</bitRange></field>
                        <field><name>CC2NP</name><description>Capture/Compare 2 Complementary Output Polarity (Only ATMR)</description><bitRange>[7:7]</bitRange></field>
                        <field><name>CC3E</name><description>Capture/Compare 3 Output Enable</description><bitRange>[8:8]</bitRange></field>
                        <field><name>CC3P</name><description>Capture/Compare 3 Output Polarity</description><bitRange>[9:9]</bitRange></field>
                        <field><name>CC3NE</name><description>Capture/Compare 3 Complementary Output Enable (Only ATMR)</description><bitRange>[10:10]</bitRange></field>
                        <field><name>CC3NP</name><description>Capture/Compare 3 Complementary Output Polarity (Only ATMR)</description><bitRange>[11:11]</bitRange></field>
                        <field><name>CC4E</name><description>Capture/Compare 4 Output Enable</description><bitRange>[12:12]</bitRange></field>
                        <field><name>CC4P</name><description>Capture/Compare 4 Output Polarity</description><bitRange>[13:13]</bitRange></field>
                    </fields>
                </register>
                <register>
                    <name>CNT</name>
                    <description>Timer Counter</description>
                    <addressOffset>0x034</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>
                <register>
                    <name>PSC</name>
                    <description>Prescaler</description>
                    <addressOffset>0x038</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>
                <register>
                    <name>ARR</name>
                    <description>Auto-reload register</description>
                    <addressOffset>0x03C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>
                <register>
                    <name>CCR1</name>
                    <description>Capture/compare register 1</description>
                    <addressOffset>0x044</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>
                <register>
                    <name>CCR2</name>
                    <description>Capture/compare register 2</description>
                    <addressOffset>0x048</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>
                <register>
                    <name>CCR3</name>
                    <description>Capture/compare register 3</description>
                    <addressOffset>0x04C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>
                <register>
                    <name>CCR4</name>
                    <description>Capture/compare register 4</description>
                    <addressOffset>0x050</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>
                <register>
                    <name>DMAEN</name>
                    <description>DMA trigger event enable</description>
                    <addressOffset>0x058</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>UDE</name><description>Update DMA Request Enable</description><bitRange>[0:0]</bitRange></field>
                        <field><name>CC1DE</name><description>Capture/Compare 1 DMA Request Enable</description><bitRange>[1:1]</bitRange></field>
                        <field><name>CC2DE</name><description>Capture/Compare 2 DMA Request Enable</description><bitRange>[2:2]</bitRange></field>
                        <field><name>CC3DE</name><description>Capture/Compare 3 DMA Request Enable</description><bitRange>[3:3]</bitRange></field>
                        <field><name>CC4DE</name><description>Capture/Compare 4 DMA Request Enable</description><bitRange>[4:4]</bitRange></field>
                        <field><name>COMDE</name><description>COM DMA Request Enable (Only ATMR)</description><bitRange>[5:5]</bitRange></field>
                        <field><name>TDE</name><description>Trigger DMA Request Enable</description><bitRange>[6:6]</bitRange></field>
                    </fields>
                </register>
            </registers>
        </peripheral>

        <!--ATMR: Advanced Timer-->
        <peripheral derivedFrom="CTMR">
            <name>ATMR</name>
            <description>Advanced Timer</description>
            <baseAddress>0x40022000</baseAddress>
            <addressBlock>
                <offset>0</offset>
                <size>0x5C</size>
                <usage>registers</usage>
            </addressBlock>
            <interrupt>
                <name>ATMR</name>
                <value>7</value>
            </interrupt>
            <registers>
                <register>
                    <name>RCR</name>
                    <description>Repetition counter register (Only ATMR)</description>
                    <addressOffset>0x040</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>
                <register>
                    <name>BDTR</name>
                    <description>Break and dead-time register (Only ATMR)</description>
                    <addressOffset>0x054</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field><name>DTG</name><description>Dead-Time Generator Setup</description><bitRange>[7:0]</bitRange></field>
                        <field>
                            <name>LOCK</name><description>Lock Configuration</description><bitRange>[9:8]</bitRange>
                            <enumeratedValues>
                                <enumeratedValue><name>Level_0</name><description>No lock</description><value>0</value></enumeratedValue>
                                <enumeratedValue><name>Level_1</name><description>Lock Level 1</description><value>1</value></enumeratedValue>
                                <enumeratedValue><name>Level_2</name><description>Lock Level 2</description><value>2</value></enumeratedValue>
                                <enumeratedValue><name>Level_3</name><description>Lock Level 3</description><value>3</value></enumeratedValue>
                            </enumeratedValues>
                        </field>
                        <field><name>OSSI</name><description>Off-state Selection for Idle Mode</description><bitRange>[10:10]</bitRange></field>
                        <field><name>OSSR</name><description>Off-state Selection for Run Mode</description><bitRange>[11:11]</bitRange></field>
                        <field><name>BKE</name><description>Break Enable</description><bitRange>[12:12]</bitRange></field>
                        <field><name>BKP</name><description>Break Polarity</description><bitRange>[13:13]</bitRange></field>
                        <field><name>AOE</name><description>Automatic Output Enable</description><bitRange>[14:14]</bitRange></field>
                        <field><name>MOE</name><description>Main Output Enable</description><bitRange>[15:15]</bitRange></field>
                    </fields>
                </register>
            </registers>
        </peripheral>
    </peripherals>
</device>
