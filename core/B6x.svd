                            <lsb>0</lsb>
                            <msb>5</msb>
                        </field>

                        <field>
                            <name>SW_RATE</name>
                            <description>only used when FSM_CTRL_SEL is 1</description>
                            <lsb>6</lsb>
                            <msb>7</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>1M</name>
                                <description>1Mbps</description>
                                <value>0</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>2M</name>
                                <description>2Mbps</description>
                                <value>1</value>
                                </enumeratedValue>
                                <!--
                                <enumeratedValue>
                                <name>forbidden</name>
                                <description>forbidden</description>
                                <value>2</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>forbidden</name>
                                <description>forbidden</description>
                                <value>3</value>
                                </enumeratedValue>
                                -->
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>SW_TX_EN</name>
                            <description>only used when FSM_CTRL_SEL is 1</description>
                            <lsb>8</lsb>
                            <msb>8</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>Tx Enable</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>Tx Disable</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>SW_RX_EN</name>
                            <description>only used when FSM_CTRL_SEL is 1</description>
                            <lsb>9</lsb>
                            <msb>9</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>Rx Enable</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>Rx Disable</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

