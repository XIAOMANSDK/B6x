                        <field>
                            <name>SADR</name>
                            <description>SADR</description>
                            <bitRange>[7:1]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>ADM2</name>
                    <description>ADM2 register</description>
