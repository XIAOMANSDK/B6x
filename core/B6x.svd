                    <fields>
                        <field>
                            <name>LDO_START_TIME</name>
                            <description>wait RF LDO stable time (ldo_start_time + 1) us , and then select PLL_RTX_SEL value, unit is us, 2~10 us, default is 3us</description>
                            <lsb>0</lsb>
                            <msb>3</msb>
                        </field>

                        <field>
                            <name>EN_PLL_TIME</name>
                            <description>after LDO stable, delay (en_pll_time + 1) us, then enable PLL; unit : us, 2~10 us, default is 3us</description>
                            <lsb>4</lsb>
                            <msb>7</msb>
                        </field>

                        <field>
                            <name>AFC_START_TIME</name>
                            <description>delay (afc_start_time +1) us to enable AFC after pll enable, 2~10 us, default is 3us</description>
                            <lsb>8</lsb>
                            <msb>11</msb>
                        </field>

                        <field>
                            <name>BPF_START_TIME</name>
                            <description>delay bpf_start_tim us to enable BPF CAL after pll enable</description>
                            <lsb>12</lsb>
                            <msb>17</msb>
                        </field>

                        <field>
                            <name>TX_END_DLY_TIME</name>
                            <description>delay (tx_end_dly_time + 1) us from neg of bb_tx_en to neg modem_tx_en</description>
                            <lsb>18</lsb>
                            <msb>21</msb>
                        </field>

                        <field>
                            <name>RX_END_DLY_TIME</name>
                            <description>delay (rx_end_dly_time + 1) us from neg of bb_rx_en to neg modem_rx_en</description>
                            <lsb>22</lsb>
                            <msb>25</msb>
                        </field>

                        <field>
                            <name>TX_PA_RAMPDOWN_TIME</name>
                            <description>delay (tx_pa_rampdown_time+1) us to start PA RAMPDOWN after neg of modem_tx_en</description>
                            <lsb>26</lsb>
                            <msb>29</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>FSM_DLY_CTRL1</name>
