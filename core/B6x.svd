                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>RC16M_WIN_SET</name>
                            <description>RC16M cnt window</description>
                            <lsb>0</lsb>
                            <msb>14</msb>
                        </field>

                        <field>
                            <name>RC16M_CNT_START</name>
                            <description>RC16M_CNT_START</description>
                            <lsb>15</lsb>
                            <msb>15</msb>
                        </field>

                        <field>
                            <name>RC16M_WIN_CNT</name>
                            <description>RC16M_WIN_CNT</description>
                            <lsb>16</lsb>
                            <msb>30</msb>
                        </field>

                        <field>
                            <name>RC16M_CNT_DONE</name>
                            <description>RC16M_CNT_DONE</description>
                            <lsb>31</lsb>
                            <msb>31</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>RTCINT_CTRL</name>
                    <description>RTCINT_CTRL register</description>
                    <addressOffset>0x01C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>RTC_INT_EN</name>
                            <description>rtc interrupt enable</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>RTC_INT_CLR</name>
                            <description>rtc intrrrupt clear</description>
                            <lsb>1</lsb>
                            <msb>1</msb>
                        </field>

                        <field>
                            <name>RTC_INT_ST</name>
                            <description>rtc interrupt status</description>
                            <lsb>2</lsb>
                            <msb>2</msb>
                        </field>

                        <field>
                            <name>RTC_SET_BUSY</name>
                            <description>RTC_SET_BUSY</description>
                            <lsb>3</lsb>
                            <msb>3</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>RTC_SEC</name>
