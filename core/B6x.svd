        <!--I2C Reg OK-->
        <peripheral>
            <name>I2C</name>
            <description>IIC</description>
            <baseAddress>0x40029000</baseAddress>
            <addressBlock>
                <offset>0x000</offset>
                <size>0x040</size>
                <usage>registers</usage>
            </addressBlock>
            <interrupt>
                <name>I2C</name>
                <value>9</value>
            </interrupt>
            <registers>
                <register>
                    <name>CONSET</name>
                    <description>i2c control reg</description>
                    <addressOffset>0x000</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>SL7VAL</name>
                            <description>7-bit address control bit</description>
                            <bitRange>[0:0]</bitRange>
                        </field>

                        <field>
                            <name>SL10VAL</name>
                            <description>10-bit address control bit</description>
                            <bitRange>[1:1]</bitRange>
                        </field>

                        <field>
                            <name>AAK</name>
                            <description>AAK</description>
                            <bitRange>[2:2]</bitRange>
                        </field>

                        <field>
                            <name>IFLG</name>
                            <description>flag signal</description>
                            <bitRange>[3:3]</bitRange>
                        </field>

                        <field>
                            <name>STP</name>
                            <description>STP</description>
                            <bitRange>[4:4]</bitRange>
                        </field>

                        <field>
                            <name>STA</name>
                            <description>STA</description>
                            <bitRange>[5:5]</bitRange>
                        </field>

                        <field>
                            <name>ENAB</name>
                            <description>I2C Enable or Disable</description>
                            <bitRange>[6:6]</bitRange>
                        </field>

                        <field>
                            <name>IEN</name>
                            <description>i2c interrupt Enable or Disable</description>
                            <bitRange>[7:7]</bitRange>
                        </field>

                        <field>
                            <name>GCAVAL</name>
                            <description>GCAVAL</description>
                            <bitRange>[8:8]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>CONCLR</name>
                    <description>i2c control clr register</description>
                    <addressOffset>0x004</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>AAC</name>
                            <description>AAC</description>
                            <bitRange>[2:2]</bitRange>
                        </field>

                        <field>
                            <name>IFLG</name>
                            <description>flag signal</description>
                            <bitRange>[3:3]</bitRange>
                        </field>

                        <field>
                            <name>STAC</name>
                            <description>STAC</description>
                            <bitRange>[5:5]</bitRange>
                        </field>

                        <field>
                            <name>ENC</name>
                            <description>ENC</description>
                            <bitRange>[6:6]</bitRange>
                        </field>

                        <field>
                            <name>IEC</name>
                            <description>IEC</description>
                            <bitRange>[7:7]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>SR</name>
                    <description>i2c status reg</description>
                    <addressOffset>0x008</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>STATUS</name>
                            <description>i2c status</description>
                            <bitRange>[7:3]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>DATA</name>
                    <description>DATA register</description>
                    <addressOffset>0x00C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>DATA</name>
                            <description>DATA</description>
                            <bitRange>[7:0]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>CLK</name>
                    <description>i2c clock (scl) speed contorl register</description>
                    <addressOffset>0x010</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>M</name>
                            <description>i2c master mode scl frequency</description>
                            <bitRange>[3:0]</bitRange>
                        </field>

                        <field>
                            <name>N</name>
