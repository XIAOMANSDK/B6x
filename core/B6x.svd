                            <bitOffset>6</bitOffset>
                            <bitWidth>3</bitWidth>
                        </field>

                        <field>
                            <name>SADC_IBSEL_VREF</name>
                            <description>SADC_IBSEL_VREF</description>
                            <bitOffset>9</bitOffset>
                            <bitWidth>3</bitWidth>
                        </field>

                        <field>
                            <name>SADC_IBSEL_BUF</name>
                            <description>SADC_IBSEL_BUF</description>
                            <bitOffset>12</bitOffset>
                            <bitWidth>3</bitWidth>
                        </field>

                        <field>
                            <name>SADC_VREF_SEL</name>
                            <description>SADC_VREF_SEL</description>
                            <bitOffset>15</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SADC_CALCAP_SEL</name>
                            <description>SADC_CALCAP_SEL</description>
                            <bitOffset>16</bitOffset>
                            <bitWidth>2</bitWidth>
                        </field>

                        <field>
                            <name>SADC_CAL_OS</name>
                            <description>SADC_CAL_OS</description>
                            <bitOffset>18</bitOffset>
                            <bitWidth>2</bitWidth>
                        </field>

                        <field>
                            <name>SADC_INBUF_BYPSS</name>
                            <description>SADC_INBUF_BYPSS</description>
                            <bitOffset>20</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>MIC_CTRL</name>
                    <description>MIC_CTRL register</description>
                    <addressOffset>0x02C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>MIC_MODE_SEL</name>
                            <description>MIC_MODE_SEL</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>MIC_PD</name>
                            <description>MIC_PD</description>
                            <bitOffset>1</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>MIC_TRIM</name>
                            <description>MIC_TRIM</description>
                            <bitOffset>2</bitOffset>
                            <bitWidth>7</bitWidth>
                        </field>

                        <field>
                            <name>MIC_VREF_SEL</name>
                            <description>MIC_VREF_SEL</description>
                            <bitOffset>9</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>PGA_BIAS_SEL</name>
                            <description>PGA_BIAS_SEL</description>
                            <bitOffset>10</bitOffset>
                            <bitWidth>2</bitWidth>
                        </field>

                        <field>
                            <name>PGA_EN</name>
                            <description>PGA_EN</description>
                            <bitOffset>12</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>PGA_VOL</name>
                            <description>PGA_VOL</description>
                            <bitOffset>13</bitOffset>
                            <bitWidth>5</bitWidth>
                        </field>

                        <field>
                            <name>PGA_VREF_SEL</name>
                            <description>PGA_VREF_SEL</description>
                            <bitOffset>18</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
                    </fields>
                </register>
            </registers>
        </peripheral>

        <!--SPIM Reg OK-->
        <peripheral>
            <name>SPIM</name>
            <description>SPI Master</description>
            <baseAddress>0x40004000</baseAddress>
            <addressBlock>
                <offset>0x000</offset>
                <size>0x01C</size>
                <usage>registers</usage>
            </addressBlock>
            <interrupt>
                <name>SPIM</name>
                <value>10</value>
            </interrupt>
            <registers>
                <register>
                    <name>RX_DATA</name>
                    <description>RX_DATA register</description>
                    <addressOffset>0x000</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>TX_DATA</name>
                    <description>TX_DATA register</description>
                    <addressOffset>0x004</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>TXRX_BGN</name>
                    <description>TXRX_BGN register</description>
                    <addressOffset>0x008</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>CTRL</name>
                    <description>CTRL register</description>
                    <addressOffset>0x00C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>SPIM_CRAT</name>
                            <description>clock rate select,clk/2^(crat+1)</description>
                            <bitRange>[3:0]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_CPHA</name>
                            <description>clock phase bit, 0: sck sample data in first edge, 1: sck sample data in second edge</description>
                            <bitRange>[4:4]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_CPOL</name>
                            <description>clock polarity bit, 0: sck is low in idle status, 1: sck is high in idle status</description>
                            <bitRange>[5:5]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_TX_DMA_EN</name>
                            <description>0: TX work as mcu mode</description>
                            <bitRange>[6:6]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_RX_DMA_EN</name>
                            <description>0: RX work as mcu mode</description>
                            <bitRange>[7:7]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_INT_EN</name>
                            <description>interrupt enable bit</description>
                            <bitRange>[8:8]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_TX_EN</name>
                            <description>transmit to SPI slave enable</description>
                            <bitRange>[9:9]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_RX_EN</name>
                            <description>receive from SPI slave enable</description>
                            <bitRange>[10:10]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_MSB_FST</name>
                            <description>1: MSB first, 0: LSB first</description>
                            <bitRange>[11:11]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_RX_PH</name>
                            <description>1: delay one phase to sample the miso</description>
                            <bitRange>[12:12]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>STATUS_CLR</name>
                    <description>STATUS_CLR register</description>
                    <addressOffset>0x010</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>SPIM_TXDAT_CLR</name>
                            <description>set 1 to clear spi TX fifo status and inner counter</description>
                            <bitRange>[0:0]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_RXDAT_CLR</name>
                            <description>set 1 to clear spi RX fifo status and inner counter</description>
                            <bitRange>[1:1]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_CLR_INTF</name>
                            <description>write 1 to clear intf status </description>
                            <bitRange>[2:2]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>STATUS</name>
                    <description>STATUS register</description>
                    <addressOffset>0x014</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>SPIM_TX_FEMPTY</name>
                            <description>tx fifo empty</description>
                            <bitRange>[0:0]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_TX_FFULL</name>
                            <description>tx fifo full</description>
                            <bitRange>[1:1]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_TX_FNUM</name>
                            <description>data number in tx fifo</description>
                            <bitRange>[4:2]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_RX_FEMPTY</name>
                            <description>rx fifo empty</description>
                            <bitRange>[5:5]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_RX_FFULL</name>
                            <description>rx fifo full</description>
                            <bitRange>[6:6]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_RX_FNUM</name>
                            <description>data number in rx fifo</description>
                            <bitRange>[9:7]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_INTF</name>
                            <description>rx or tx interrupt flag</description>
                            <bitRange>[10:10]</bitRange>
                        </field>

                        <field>
                            <name>SPIM_BUSY</name>
                            <description>spim transfer busy signal</description>
                            <bitRange>[11:11]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>DAT_LEN</name>
                    <description>DAT_LEN register</description>
                    <addressOffset>0x018</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>
            </registers>
        </peripheral>

        <!--SPIS Reg OK-->
        <peripheral>
            <name>SPIS</name>
            <description>SPI Slave</description>
            <baseAddress>0x40005000</baseAddress>
            <addressBlock>
                <offset>0x000</offset>
                <size>0x014</size>
                <usage>registers</usage>
            </addressBlock>
            <interrupt>
                <name>SPIS</name>
                <value>11</value>
            </interrupt>
            <registers>
                <register>
                    <name>CTRL</name>
                    <description>CTRL register</description>
                    <addressOffset>0x000</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>SPIS_LSBFIRST</name>
                            <description>0: MSB first, 1: LSB first</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_CPOL</name>
                            <description>0: sample the data at the first clock edge, 1: sample the data at the second clock edge</description>
                            <bitOffset>1</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_CPHA</name>
                            <description>0: sample the data at the first clock edge, 1: sample the data at the second clock edge</description>
                            <bitOffset>2</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_RX_EN</name>
                            <description>spis rx control signal</description>
                            <bitOffset>3</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_RXINT_EN</name>
                            <description>SPIS_RXINT_EN</description>
                            <bitOffset>4</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_TX_DMA_MODE</name>
                            <description>1: DMA mode, 0: MCU mode</description>
                            <bitOffset>5</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_RX_DMA_MODE</name>
                            <description>1: DMA mode, 0: MCU mode</description>
                            <bitOffset>6</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_EN</name>
                            <description>SPIS_EN</description>
                            <bitOffset>7</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_OT_WIN</name>
                            <description>config overtime window</description>
                            <bitRange>[15:8]</bitRange>
                        </field>

                        <field>
                            <name>SPIS_OT_EN</name>
                            <description>SPIS overtime enable</description>
                            <bitRange>[16:16]</bitRange>
                        </field>

                        <field>
                            <name>SPIS_OTINT_EN</name>
                            <description>SPIS overtime interrupt enable</description>
                            <bitRange>[17:17]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>STATUS</name>
                    <description>STATUS register</description>
                    <addressOffset>0x004</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>SPIS_RXFIFO_EMPTY</name>
                            <description>rxfifo empty</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_RXFIFO_FULL</name>
                            <description>rxfifo full</description>
                            <bitOffset>1</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_RXFIFO_NUM</name>
                            <description>the SPIS RX data number in rxfifo</description>
                            <bitOffset>2</bitOffset>
                            <bitWidth>3</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_RX_OVERRUN</name>
                            <description>SPIS rxfifo overrun error signal</description>
                            <bitOffset>6</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_CS</name>
                            <description>0: SPIS is selected, 1: SPIS is not selected</description>
                            <bitOffset>7</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_TXFIFO_EMPTY</name>
                            <description>txfifo empty</description>
                            <bitOffset>8</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_TXFIFO_FULL</name>
                            <description>txfifo full</description>
                            <bitOffset>9</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_TXFIFO_NUM</name>
                            <description>the SPIS TX data number in txfifo</description>
                            <bitOffset>10</bitOffset>
                            <bitWidth>3</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_RXINT_ST</name>
                            <description>when SPIS RX 1 byte,spis_rxint is 1, cleared by spis_rxint_clr</description>
                            <bitRange>[16:16]</bitRange>
                        </field>

                        <field>
                            <name>SPIS_OTINT_ST</name>
                            <description>set as 1 when SPIS overtime event happen</description>
                            <bitRange>[17:17]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>INFO_CLR</name>
                    <description>INFO_CLR register</description>
                    <addressOffset>0x008</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>SPIS_RX_OVERRUN_CLR</name>
                            <description>use to clear spis_rx_overrun</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_TXDAT_CLR</name>
                            <description>use to clear SPIS txfifo point and data reg</description>
                            <bitOffset>1</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_RXDAT_CLR</name>
                            <description>use to clear SPIS rxfifo point and data reg</description>
                            <bitOffset>2</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_RXINT_CLR</name>
                            <description>use clear spis_rxint</description>
                            <bitOffset>3</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>

                        <field>
                            <name>SPIS_OTINT_CLR</name>
                            <description>use clear spis_otint</description>
                            <bitRange>[4:4]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>TX_DAT</name>
                    <description>TX_DAT register</description>
                    <addressOffset>0x00C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>RX_DAT</name>
                    <description>RX_DAT register</description>
                    <addressOffset>0x010</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>
            </registers>
        </peripheral>

        <!--IWDT Reg OK-->
        <peripheral>
            <name>IWDT</name>
            <description>Independent WatchDog Timer</description>
            <baseAddress>0x4002A000</baseAddress>
            <addressBlock>
                <offset>0x000</offset>
                <size>0x104</size>
                <usage>registers</usage>
            </addressBlock>
            <interrupt>
                <name>IWDT</name>
                <value>1</value>
            </interrupt>
            <registers>
                <register>
                    <name>LOAD</name>
                    <description>reload  value register</description>
                    <addressOffset>0x000</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>VALUE</name>
                    <description>current value register</description>
                    <addressOffset>0x004</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>CTRL</name>
                    <description>CTRL register</description>
                    <addressOffset>0x008</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>EN</name>
                            <description>iwdg enable</description>
                            <bitRange>[0:0]</bitRange>
                        </field>

                        <field>
                            <name>INTEN</name>
                            <description>iwdg interrupt enable</description>
                            <bitRange>[1:1]</bitRange>
                        </field>

                        <field>
                            <name>RSTEN</name>
                            <description>iwdg reset enable</description>
                            <bitRange>[2:2]</bitRange>
                        </field>

                        <field>
                            <name>CLKSEL</name>
                            <description>0:iwdt clk select apbclk, 1:iwdt clk select lsi</description>
                            <bitRange>[3:3]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>INTCLR</name>
                    <description>interrupt flag clear register</description>
                    <addressOffset>0x00C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>RIS</name>
                    <description>interrupt flag register</description>
                    <addressOffset>0x010</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>LOCK</name>
                    <description>write 0x1ACCE551 to unlock</description>
                    <addressOffset>0x100</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>
            </registers>
        </peripheral>

        <!--APBMISC Reg OK-->
        <peripheral>
            <name>APBMISC</name>
            <description>APBMISC</description>
            <baseAddress>0x40031000</baseAddress>
            <addressBlock>
                <offset>0x000</offset>
                <size>0x088</size>
                <usage>registers</usage>
            </addressBlock>

            <registers>
                <register>
                    <name>RC32K_CALIB_ST</name>
                    <description>RC32K_CALIB_ST register</description>
                    <addressOffset>0x000</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>RC32K_MSB_CALIB</name>
                            <description>the final RC trim value</description>
                            <lsb>0</lsb>
                            <msb>3</msb>
                        </field>

                        <field>
                            <name>RC32K_LSB_CALIB</name>
                            <description>RC32K_LSB_CALIB</description>
                            <lsb>16</lsb>
                            <msb>25</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>RCCALIB_CTRL</name>
                    <description>RCCALIB_CTRL register</description>
                    <addressOffset>0x004</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>RCCALIB_TARGET</name>
                            <description>rccalib_target = Fref * (rccalib_cycles+1) / Flsi</description>
                            <lsb>0</lsb>
                            <msb>19</msb>
                        </field>

                        <field>
                            <name>RCCALIB_CYCLES</name>
                            <description>each RC calib step window is rccalib_cycles of LSI clock</description>
                            <lsb>20</lsb>
                            <msb>27</msb>
                        </field>

                        <field>
                            <name>RCCALIB_SCAL_EN</name>
                            <description>RCCALIB_SCAL_EN enable</description>
                            <lsb>28</lsb>
                            <msb>28</msb>
                        </field>

                        <field>
                            <name>RCCALIB_DLY</name>
                            <description>when is 1: add one LSI clock delay between msb_calib or lsb_calib change to start count</description>
                            <lsb>29</lsb>
                            <msb>29</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>RCCALIB_START</name>
                    <description>RCCALIB_START register</description>
                    <addressOffset>0x008</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>RCFREQ_GET</name>
                    <description>RCFREQ_GET</description>
                    <addressOffset>0x00C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>RC_FREQ_VAL</name>
                    <description>RC_FREQ_VAL</description>
                    <addressOffset>0x010</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>RCCALIB_STCLR</name>
                    <description>RCCALIB_STCLR register</description>
                    <addressOffset>0x014</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>RCCALIB_DONE</name>
                            <description>RCCALIB_DONE</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>RCFREQ_DONE</name>
                            <description>RCFREQ_DONE</description>
                            <lsb>1</lsb>
                            <msb>1</msb>
                        </field>

                        <field>
                            <name>RCCALIB_DONE_CLR</name>
                            <description>RCCALIB_DONE_CLR</description>
                            <lsb>8</lsb>
                            <msb>8</msb>
                        </field>

                        <field>
                            <name>RCFREQ_DONE_CLR</name>
                            <description>RCFREQ_DONE_CLR</description>
                            <lsb>9</lsb>
                            <msb>9</msb>
                        </field>
