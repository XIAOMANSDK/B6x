                            <lsb>20</lsb>
                            <msb>20</msb>
                        </field>

                        <field>
                            <name>CF_BW12M_ADJ_REG</name>
                            <description>used when ana_test_en is 1</description>
                            <lsb>21</lsb>
                            <msb>21</msb>
                        </field>

                        <field>
                            <name>DAC_VCTRL_BUF_REG</name>
                            <description>DAC_VCTRL_BUF_REG</description>
                            <bitRange>[22:22]</bitRange>
                        </field>

                        <field>
                            <name>DAC_VCTRL_EN_REG</name>
                            <description>DAC_VCTRL_EN_REG</description>
                            <bitRange>[23:23]</bitRange>
                        </field>

                        <field>
                            <name>ANT_CAP_RX</name>
                            <description>ANT_CAP_RX</description>
                            <bitRange>[27:24]</bitRange>
                        </field>

                        <field>
                            <name>ANT_CAP_TX</name>
                            <description>ANT_CAP_TX</description>
                            <bitRange>[31:28]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>PLL_ANA_CTRL</name>
                    <description>PLL_ANA_CTRL register</description>
                    <addressOffset>0x06C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>PLL_BW_ADJ</name>
                            <description>PLL_BW_ADJ</description>
                            <lsb>0</lsb>
                            <msb>2</msb>
                        </field>

                        <field>
                            <name>PLL_CP_OS_EN</name>
                            <description>PLL_CP_OS_EN</description>
                            <lsb>3</lsb>
                            <msb>3</msb>
                        </field>

                        <field>
                            <name>PLL_CP_OS_ADJ</name>
                            <description>PLL_CP_OS_ADJ</description>
                            <lsb>4</lsb>
                            <msb>7</msb>
                        </field>

                        <field>
                            <name>PLL_DIV_ADJ</name>
                            <description>PLL_DIV_ADJ</description>
                            <lsb>8</lsb>
                            <msb>9</msb>
                        </field>

                        <field>
                            <name>PLL_DI_P</name>
                            <description>PLL_DI_P</description>
                            <lsb>10</lsb>
                            <msb>14</msb>
                        </field>

                        <field>
                            <name>PLL_FAST_LOCK_EN</name>
                            <description>PLL_FAST_LOCK_EN</description>
                            <lsb>15</lsb>
                            <msb>15</msb>
                        </field>

                        <field>
                            <name>PLL_FBDIV_RST_EXT</name>
                            <description>PLL_FBDIV_RST_EXT</description>
                            <lsb>16</lsb>
                            <msb>16</msb>
                        </field>

                        <field>
                            <name>PLL_FBDIV_RST_SEL</name>
                            <description>PLL_FBDIV_RST_SEL</description>
                            <lsb>17</lsb>
                            <msb>17</msb>
                        </field>

                        <field>
                            <name>PLL_LOCK_BYPS</name>
                            <description>PLL_LOCK_BYPS</description>
                            <lsb>18</lsb>
                            <msb>18</msb>
                        </field>

                        <field>
                            <name>PLL_PS_CNT_RST_SEL</name>
                            <description>PLL_PS_CNT_RST_SEL</description>
                            <lsb>19</lsb>
                            <msb>19</msb>
                        </field>

                        <field>
                            <name>PLL_REF_SEL</name>
                            <description>PLL_REF_SEL</description>
                            <lsb>20</lsb>
                            <msb>20</msb>
                        </field>

                        <field>
                            <name>PLL_SDM_TEST_EN</name>
                            <description>PLL_SDM_TEST_EN</description>
                            <lsb>21</lsb>
                            <msb>21</msb>
                        </field>

                        <field>
                            <name>PLL_VCO_ADJ</name>
                            <description>PLL_VCO_ADJ</description>
                            <lsb>22</lsb>
                            <msb>24</msb>
                        </field>

                        <field>
                            <name>PLL_VCTRL_EXT_EN</name>
                            <description>PLL_VCTRL_EXT_EN</description>
                            <lsb>25</lsb>
                            <msb>25</msb>
                        </field>

                        <field>
                            <name>PLL_VREF_ADJ</name>
                            <description>PLL_VREF_ADJ</description>
                            <lsb>26</lsb>
                            <msb>28</msb>
                        </field>

                        <field>
                            <name>PLL_MIX_SEL</name>
                            <description>0: +2M IF for RX, 1: -2M IF for RX to RF Analog block</description>
                            <lsb>29</lsb>
                            <msb>29</msb>
                        </field>

                        <field>
                            <name>PLL_RTX_SEL_REG</name>
                            <description>used when ana_test_en is 1</description>
                            <lsb>30</lsb>
                            <msb>30</msb>
                        </field>

                        <field>
                            <name>PLL_SEL_RTX_BW</name>
                            <description>direct to RF Analog block</description>
                            <lsb>31</lsb>
                            <msb>31</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>RF_RSV</name>
                    <description>RF_RSV register</description>
                    <addressOffset>0x070</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>RF_ANA_ST0</name>
                    <description>RF_ANA_ST0 register</description>
                    <addressOffset>0x074</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>AGC_STATE0</name>
                            <description>AGC_STATE0</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>AGC_STATE1</name>
                            <description>AGC_STATE1</description>
                            <lsb>1</lsb>
                            <msb>1</msb>
                        </field>

                        <field>
                            <name>BPF_CAL_CODE</name>
                            <description>BPF_CAL_CODE</description>
                            <lsb>2</lsb>
                            <msb>7</msb>
                        </field>

                        <field>
                            <name>BG_VREF_OK12</name>
                            <description>BG_VREF_OK12</description>
                            <lsb>8</lsb>
                            <msb>8</msb>
                        </field>

                        <field>
                            <name>BPF_CAL_DONE</name>
                            <description>BPF_CAL_DONE</description>
                            <lsb>9</lsb>
                            <msb>9</msb>
                        </field>

                        <field>
                            <name>PLL_LOCK</name>
                            <description>PLL_LOCK</description>
                            <lsb>10</lsb>
                            <msb>10</msb>
                        </field>

                        <field>
                            <name>FAST_LOCK_DONE</name>
                            <description>FAST_LOCK_DONE</description>
                            <lsb>11</lsb>
                            <msb>11</msb>
                        </field>

                        <field>
                            <name>AGC_STATE_TEST</name>
                            <description>AGC_STATE_TEST</description>
                            <lsb>12</lsb>
                            <msb>13</msb>
                        </field>
                    </fields>
                </register>
            </registers>
        </peripheral>

        <!-- AON Reg OK-->
        <peripheral>
            <name>AON</name>
            <description>Always On Domain</description>
            <baseAddress>0x40030000</baseAddress>
            <addressBlock>
                <offset>0x000</offset>
                <size>0x02C</size>
                <usage>registers</usage>
            </addressBlock>
            <interrupt>
                <name>AON_PMU</name>
                <value>14</value>
            </interrupt>
            <!--
            <groupName>AON</groupName>
            -->
            <registers>
                <register>
                    <name>BACKUP0</name>
                    <description>valid-bit:16, can't be reset by pin reset, por12_bk_stb</description>
                    <addressOffset>0x000</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>BACKUP1</name>
                    <description>valid-bit:8, can't be reset by pin reset, por12_bk_stb</description>
                    <addressOffset>0x004</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>BKHOLD_CTRL</name>
                    <description>BKHOLD_CTRL register</description>
                    <addressOffset>0x008</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>RC32K_MSB_TRIM_CFG</name>
                            <description>rc32k_msb_trim_cfg</description>
                            <lsb>0</lsb>
                            <msb>3</msb>
                        </field>

                        <field>
                            <name>RC32K_LSB_TRIM_CFG</name>
                            <description>rc32k_lsb_trim_cfg</description>
                            <lsb>4</lsb>
                            <msb>13</msb>
                        </field>

                        <field>
                            <name>XOSC_EST_MODE</name>
                            <description>XOSC EST MODE</description>
                            <lsb>14</lsb>
                            <msb>14</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>extarnal clock through XOSC16M_IN PAD into chip and XOSC16M_OUT PAD is not driven by XOSC16M </description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>the XOSC16M_IN and XOSC16M_OUT are connected with crystal oscillator</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>PIOA19_FUNC_SEL</name>
                            <description>PIOA19_FUNC_SEL</description>
                            <lsb>15</lsb>
                            <msb>15</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>pioa19 used as GPIO, can't be reset by pin reset</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>pioa19 used as reset pin</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>AONLDO_TRIM_RUN</name>
                            <description>LDOBK_TRIM, inverter the high two bits</description>
                            <lsb>16</lsb>
                            <msb>19</msb>
                        </field>

                        <field>
                            <name>CORELDO_TRIM_RUN</name>
                            <description>CORE LDO trim, used when ST_RUN</description>
                            <lsb>20</lsb>
                            <msb>24</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>BACKUP2</name>
                    <description>valid-bit:8, can't be reset by pin reset, por12_bk_stb</description>
                    <addressOffset>0x00C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>BLE_RTC_CTL</name>
                    <description>BLE_RTC_CTL register</description>
                    <addressOffset>0x010</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>BLELOWCLK_EN</name>
                            <description>BLELOWCLK_EN</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>BLELOWCLK_SEL</name>
                            <description>BLE low power clock source select</description>
                            <lsb>1</lsb>
                            <msb>1</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>HES Div 32K</name>
                                <description>HSE clock/500</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>RC32K Clock</name>
                                <description>lsi clock, 32K</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>RTC_EN</name>
                            <description>RTC_EN</description>
                            <lsb>2</lsb>
                            <msb>2</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>RTC enable</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>RTC disable</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>SCAN_MODE_CTRL</name>
                    <description>how to into scan mode 1: CPU write this scan_mode_req 2: wait 200us</description>
                    <addressOffset>0x014</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>SCAN_MODE_REQ</name>
                            <description>SCAN_MODE_REQ</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>SCAN_ZIP_CFG</name>
                            <description>SCAN_ZIP_CFG</description>
                            <lsb>1</lsb>
                            <msb>1</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>PMU_CTRL</name>
                    <description>BLE_RTC_CTL register</description>
                    <addressOffset>0x018</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>AUTO_DIS_RC32K</name>
                            <description>when auto_dis_rc32k is 1 RC32K is auto disable when chip in poweroff state or deepsleep state, RC32K is auto enable when wakeup event happen for poweroff state or deepsleep</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>CORELDO_EN_RUN</name>
                            <description>CORELDO_EN_RUN</description>
                            <lsb>1</lsb>
                            <msb>1</msb>
                        </field>

                        <field>
                            <name>OSC_EN_RUN</name>
                            <description>OSC_EN_RUN</description>
                            <lsb>2</lsb>
                            <msb>2</msb>
                        </field>

                        <field>
                            <name>RC32K_EN_RUN</name>
                            <description>only use when PMU in ST_RUN, RC32K</description>
                            <lsb>3</lsb>
                            <msb>3</msb>
                        </field>

                        <field>
                            <name>EM_PD_EN</name>
                            <description>EM power down or power enable</description>
                            <lsb>4</lsb>
                            <msb>4</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>EM is power down</name>
                                <description>EM is power down</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>EN is power enable</name>
                                <description>EN is power enable</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>EM_ACCESS_EN</name>
                            <description>EM access enable</description>
                            <lsb>5</lsb>
                            <msb>5</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>EM is can be access</name>
                                <description>EM is can be access</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>EM is isolation</name>
                                <description>EM is isolation</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>POWEROFF_LOG</name>
                            <description>when is 1, chip is powerup from POWEROFF state, else means chip is initial powerup or powerup from BOD event happen</description>
                            <lsb>8</lsb>
                            <msb>8</msb>
                        </field>

                        <field>
                            <name>EM_PD_ACK</name>
                            <description>EM_PD_ACK</description>
                            <lsb>9</lsb>
                            <msb>9</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>PMU_WKUP_CTRL</name>
                    <description>PMU_WKUP_CTRL register</description>
                    <addressOffset>0x01C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>BLE_WKUP_SEL</name>
                            <description>both use when deepsleep or poweroff state, when poweroff mode, only ble_osc_en can be used</description>
                            <lsb>0</lsb>
                            <msb>1</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Disable Ble Wakeup</name>
                                <description>disable ble wakeup</description>
                                <value>0</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Ble OSC_En Wakeup</name>
                                <description>select ble_osc_en as wakeup source</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Ble Radio_En Wakeup</name>
                                <description>select ble_radio_en as wakeup source</description>
                                <value>2</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Ble Lp Wakeup</name>
                                <description>select ble_wakeup_lp as wakeup source</description>
                                <value>3</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>BLE_LATCH_N</name>
                            <description>config as 0 before chip into poweroff mode, set as 1 after chip powerup and retain the BB state</description>
                            <lsb>2</lsb>
                            <msb>2</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>enable the signal from BB to BLE LP counter</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>latch the signal from BB to BLE LP counter</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>IO_WKUP_EN</name>
                            <description>both use when deepsleep or poweroff state</description>
                            <lsb>3</lsb>
                            <msb>3</msb>
                        </field>

                        <field>
                            <name>RTC_WKUP_EN</name>
                            <description>both use when deepsleep or poweroff state</description>
                            <lsb>4</lsb>
                            <msb>4</msb>
                        </field>

                        <field>
                            <name>IO_LATCH_N</name>
                            <description>config as 0 before chip into poweroff mode, set as 1 after chip powerup and retain the GPIO config</description>
                            <lsb>5</lsb>
                            <msb>5</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>enable the GPIO control signal from core to AON</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>latch the GPIO control signal from core to AON</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>RC32K_TRIM_SEL</name>
                            <description>RC32K_TRIM_SEL</description>
                            <lsb>6</lsb>
                            <msb>6</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Enable</name>
                                <description>use RC32K calib result control the RC32K freq</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Disable</name>
                                <description>use rc32k_msb_trim_cfg and rc32k_lsb_trim_cfg control the RC32K freq</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>PMU_WKUP_ST</name>
                    <description>PMU_WKUP_ST register</description>
                    <addressOffset>0x020</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>IO_WKUP_ST</name>
                            <description>IO_WKUP_ST</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>BLE_WKUP_ST</name>
                            <description>BLE_WKUP_ST</description>
                            <lsb>1</lsb>
                            <msb>1</msb>
                        </field>

                        <field>
                            <name>RTC_WKUP_ST</name>
                            <description>RTC_WKUP_ST</description>
                            <lsb>2</lsb>
                            <msb>2</msb>
                        </field>

                        <field>
                            <name>AON_PMU_INT</name>
                            <description>AON_PMU_INT</description>
                            <lsb>3</lsb>
                            <msb>3</msb>
                        </field>

                        <field>
                            <name>BOD12_OUT12_ST</name>
                            <description>BOD12_OUT12_ST</description>
                            <lsb>8</lsb>
                            <msb>8</msb>
                        </field>

                        <field>
                            <name>LVD33_OUT12_ST</name>
                            <description>LVD33_OUT12_ST</description>
                            <lsb>9</lsb>
                            <msb>9</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>PMU_ANA_CTRL</name>
                    <description>PMU_ANA_CTRL register</description>
                    <addressOffset>0x024</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>BK_BOD_TRIM</name>
                            <description>BK_BOD_TRIM</description>
                            <lsb>0</lsb>
                            <msb>2</msb>
                        </field>

                        <field>
                            <name>LDO_BOD_EN</name>
                            <description>detect the VDD12, when VDD12 little vth: BOD12_OUT12 is 1, else BOD12_OUT12 is 0</description>
                            <lsb>3</lsb>
                            <msb>3</msb>
                        </field>

                        <field>
                            <name>LDO_BOD_TEST_EN</name>
                            <description>LDO_BOD_TEST_EN</description>
                            <lsb>4</lsb>
                            <msb>4</msb>
                        </field>

                        <field>
                            <name>LDO12_IBSEL</name>
                            <description>LDO12_IBSEL</description>
                            <lsb>5</lsb>
                            <msb>9</msb>
                        </field>

                        <field>
                            <name>LDO_LVD_EN</name>
                            <description>LDO_LVD_EN</description>
