        <!--CACHE Reg OK-->
        <peripheral>
            <name>CACHE</name>
            <description>CACHE</description>
            <baseAddress>0x19000000</baseAddress>
            <addressBlock>
                <offset>0x000</offset>
                <size>0x01C</size>
                <usage>registers</usage>
            </addressBlock>

            <registers>
                <register>
                    <name>CCR</name>
                    <description>CCR register</description>
                    <addressOffset>0x000</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>CACHE_EN</name>
                            <description>0---cache disable, 1---cache enable</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>CCFR</name>
                    <description>CCFR register</description>
                    <addressOffset>0x004</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>CACHE_INST_DATA</name>
                            <description>0---only instruction data can be cached, 1---both instruction and common data can be cached</description>
                            <lsb>3</lsb>
                            <msb>3</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>CIR</name>
                    <description>CIR register</description>
                    <addressOffset>0x008</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>INV_ALL</name>
                            <description>The control bit of invalid all cache lines operation.</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>INV_ONE</name>
                            <description>The control bit of invalid one cache line operation.</description>
                            <lsb>1</lsb>
                            <msb>1</msb>
                        </field>

                        <field>
                            <name>INV_ADDR</name>
                            <description>The high bits of cache line address of invalid one cache line operation.</description>
                            <lsb>4</lsb>
                            <msb>31</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>CRCR0</name>
                    <description>CRCR0 register</description>
                    <addressOffset>0x00C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>CRCR0_EN</name>
                            <description>Cache region enable bit.</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>SIZE</name>
                            <description>These control bits indicate the size of cacheable region.</description>
                            <lsb>1</lsb>
                            <msb>5</msb>
                        </field>

                        <field>
                            <name>BASE_ADDR</name>
                            <description>High 22 bits of base address of cacheable region.</description>
                            <lsb>10</lsb>
                            <msb>31</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>CRCR1</name>
                    <description>CRCR1 register</description>
                    <addressOffset>0x010</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>CRCR1_EN</name>
                            <description>Cache region enable bit.</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>SIZE</name>
                            <description>These control bits indicate the size of cacheable region.</description>
                            <lsb>1</lsb>
                            <msb>5</msb>
                        </field>

                        <field>
                            <name>BASE_ADDR</name>
                            <description>High 22 bits of base address of cacheable region.</description>
                            <lsb>10</lsb>
                            <msb>31</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>CRCR2</name>
                    <description>CRCR2 register</description>
                    <addressOffset>0x014</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>CRCR2_EN</name>
                            <description>Cache region enable bit.</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>SIZE</name>
                            <description>These control bits indicate the size of cacheable region.</description>
                            <lsb>1</lsb>
                            <msb>5</msb>
                        </field>

                        <field>
                            <name>BASE_ADDR</name>
                            <description>High 22 bits of base address of cacheable region.</description>
                            <lsb>10</lsb>
                            <msb>31</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>CRCR3</name>
                    <description>CRCR3 register</description>
                    <addressOffset>0x018</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>CRCR3_EN</name>
                            <description>Cache region enable bit.</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>SIZE</name>
                            <description>These control bits indicate the size of cacheable region.</description>
                            <lsb>1</lsb>
                            <msb>5</msb>
                        </field>

                        <field>
                            <name>BASE_ADDR</name>
                            <description>High 22 bits of base address of cacheable region.</description>
                            <lsb>10</lsb>
                            <msb>31</msb>
                        </field>
                    </fields>
                </register>
            </registers>
        </peripheral>

        <!--DMA Reg OK-->
        <peripheral>
            <name>DMA</name>
            <description>DMA </description>
            <groupName>DMA</groupName>
            <baseAddress>0x40026000</baseAddress>
            <addressBlock>
            <offset>0</offset>
            <size>0xe4C</size>
            <usage>registers</usage>
            </addressBlock>
            <registers>
                <register>
                    <name>STA</name>
                    <description>DMA Status Register.</description>
                    <addressOffset>0x000</addressOffset>
