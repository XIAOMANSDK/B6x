                            <lsb>0</lsb>
                            <msb>23</msb>
                        </field>

                        <field>
                            <name>SW_PLL_DI_S</name>
                            <description>SW_PLL_DI_S</description>
                            <lsb>24</lsb>
                            <msb>28</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>PLL_DYM_CTRL</name>
                    <description>PLL_DYM_CTRL register</description>
                    <addressOffset>0x01C</addressOffset>
