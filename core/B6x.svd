                        </field>
                    </fields>
                </register>

                <register>
                    <name>BLE_LP_CTRL</name>
                    <description>BLE_LP_CTRL register</description>
                    <addressOffset>0x058</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>BLE_WAKEUP_REQ</name>
                            <description>write 1, software wakeup the BB from BB in deepsleep</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>BLE_OSC_EN_ST</name>
                            <description>BLE_OSC_EN_ST</description>
                            <lsb>8</lsb>
                            <msb>8</msb>
                        </field>

                        <field>
                            <name>BLE_RADIO_EN_ST</name>
                            <description>BLE_RADIO_EN_ST</description>
                            <lsb>9</lsb>
                            <msb>9</msb>
                        </field>

                        <field>
                            <name>BLE_SAMP_VALID</name>
                            <description>when is 1, ble_clkncnt_samp and ble_finecnt_samp can be read, auto cleared by HW</description>
                            <lsb>10</lsb>
                            <msb>10</msb>
                        </field>

                        <field>
                            <name>BLE_DP_VALID</name>
                            <description>when is 1, BB is deepsleep, and the remained sleep time is larger than auto cleared when BB exit deepsleep</description>
                            <lsb>11</lsb>
                            <msb>11</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>BLE_SYNC_TIME</name>
                    <description>BLE_SYNC_TIME register</description>
                    <addressOffset>0x05C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>BLE_FINECNT_BOUND</name>
                    <description>BLE_FINECNT_BOUND register</description>
                    <addressOffset>0x060</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>BLE_CLKNCNT_SAMP</name>
                    <description>BLE_CLKNCNT_SAMP register</description>
                    <addressOffset>0x064</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>BLE_FINECNT_SAMP</name>
                    <description>BLE_FINECNT_SAMP register</description>
                    <addressOffset>0x068</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>BLE_CLKNCNT_CFG</name>
                    <description>BLE_CLKNCNT_CFG register</description>
                    <addressOffset>0x06C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>BLE_FINECNT_CFG</name>
                    <description>BLE_FINECNT_CFG register</description>
                    <addressOffset>0x070</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>BLE_DP_TWCORE</name>
                    <description>the threhold for BB remained deepsleep time for Core go into Deepsleep</description>
                    <addressOffset>0x074</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>BLE_UPLOAD</name>
                    <description>BLE_UPLOAD register</description>
                    <addressOffset>0x078</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>DPLL_CTRL</name>
                    <description>DPLL_CTRL register</description>
                    <addressOffset>0x07C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>DPLL2_EN</name>
                            <description>DPLL2_EN</description>
                            <lsb>2</lsb>
                            <msb>2</msb>
                        </field>

                        <field>
                            <name>DPLL2_LOCK_BYPASS_EN</name>
                            <description>DPLL2_LOCK_BYPASS_EN</description>
                            <lsb>3</lsb>
                            <msb>3</msb>
                        </field>

                        <field>
                            <name>DPLL2_EN_CLK48M</name>
                            <description>DPLL2_EN_CLK48M</description>
                            <lsb>4</lsb>
                            <msb>4</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>ANAMISC_CTRL</name>
                    <description>ANAMISC_CTRL register</description>
                    <addressOffset>0x080</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>TESTA_CONN2XO_EN</name>
                            <description>TESTA_CONN2XO_EN</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                        </field>

                        <field>
                            <name>LDO_BOD_TEST_EN</name>
                            <description>LDO_BOD_TEST_EN</description>
                            <lsb>1</lsb>
                            <msb>1</msb>
                        </field>

                        <field>
                            <name>LDO_BOD_INT_EN</name>
                            <description>LDO_BOD_INT_EN</description>
                            <lsb>2</lsb>
                            <msb>2</msb>
                        </field>

                        <field>
                            <name>LDO_LVD_INT_EN</name>
                            <description>LDO_LVD_INT_EN</description>
                            <lsb>3</lsb>
                            <msb>3</msb>
                        </field>

                        <field>
                            <name>BK_VBK_TEST_EN</name>
                            <description>BK_VBK_TEST_EN</description>
                            <lsb>4</lsb>
                            <msb>4</msb>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>ANAMISC_ST</name>
                    <description>ANAMISC_ST register</description>
                    <addressOffset>0x084</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>DPLL2_LOCK_READY</name>
                            <description>DPLL2_LOCK_READY</description>
                            <lsb>1</lsb>
                            <msb>1</msb>
                        </field>

                        <field>
                            <name>LVD_MODE</name>
                            <description>0: 1.8V IO voltage, 1: 3.3V IO valtage</description>
                            <lsb>2</lsb>
                            <msb>2</msb>
                        </field>
                    </fields>
                </register>
            </registers>
        </peripheral>

        <!--UART Reg OK-->
        <peripheral>
            <name>UART1</name>
            <description>UART1</description>
            <groupName>UART</groupName>
            <baseAddress>0x40023000</baseAddress>
            <addressBlock>
                <offset>0x000</offset>
                <size>0x03C</size>
                <usage>registers</usage>
            </addressBlock>

            <interrupt>
                <name>UART1_IRQ</name>
                <value>12</value>
            </interrupt>

            <registers>
                <register>
                    <name>RBR</name>
                    <description>Receiver Buffer Register</description>
                    <addressOffset>0x000</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>TBR</name>
                    <description>Transmit Buffer Register</description>
                    <addressOffset>0x004</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>BRR</name>
                    <description>Baud rate register</description>
                    <addressOffset>0x008</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>LCR</name>
                    <description>Line  control register.</description>
                    <addressOffset>0x00C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>DLS</name>
                            <description>Data length selection</description>
                            <bitRange>[1:0]</bitRange>
                        </field>

                        <field>
                            <name>STOP</name>
                            <description>Stop bit</description>
                            <bitRange>[2:2]</bitRange>
                        </field>

                        <field>
                            <name>PE</name>
                            <description>Parity bit enable</description>
                            <bitRange>[3:3]</bitRange>
                        </field>

                        <field>
                            <name>PS</name>
                            <description>Parity bit selection</description>
                            <bitRange>[4:4]</bitRange>
                        </field>

                        <field>
                            <name>RXEN</name>
                            <description>Receive enable</description>
                            <bitRange>[5:5]</bitRange>
                        </field>

                        <field>
                            <name>BC</name>
                            <description>Break control bit</description>
                            <bitRange>[6:6]</bitRange>
                        </field>

                        <field>
                            <name>BRWEN</name>
                            <description>Baud rate register write enable</description>
                            <bitRange>[7:7]</bitRange>
                        </field>

                        <field>
                            <name>RTOEN</name>
                            <description>Receiver timeout enable</description>
                            <bitRange>[8:8]</bitRange>
                        </field>

                        <field>
                            <name>MSBFIRST</name>
                            <description>Most significant bit first</description>
                            <bitRange>[9:9]</bitRange>
                        </field>

                        <field>
                            <name>DATAINV</name>
                            <description>Binary data inversion</description>
                            <bitRange>[10:10]</bitRange>
                        </field>

                        <field>
                            <name>RXINV</name>
                            <description>RX pin active level inversion</description>
                            <bitRange>[11:11]</bitRange>
                        </field>

                        <field>
                            <name>TXINV</name>
                            <description>TX pin active level inversion</description>
                            <bitRange>[12:12]</bitRange>
                        </field>

                        <field>
                            <name>SWAP</name>
                            <description>Swap TX/RX pins</description>
                            <bitRange>[13:13]</bitRange>
                        </field>

                        <field>
                            <name>RTO_SEL</name>
                            <description>receiver timeout mode select: 0:CPU, 1:DMA</description>
                            <bitRange>[14:14]</bitRange>
                        </field>
                    </fields>
                </register>

                <register>
                    <name>MCR</name>
                    <description>Mode control register</description>
                    <addressOffset>0x010</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>IREN</name>
                            <description>IrDA mode enable.</description>
                            <bitRange>[0:0]</bitRange>
                        </field>
                        <field>
                            <name>LBEN</name>
                            <description>LoopBack enable.</description>
                            <bitRange>[1:1]</bitRange>
