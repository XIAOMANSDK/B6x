                            <name>RF_EXT_EN</name>
                            <description>RF_EXT_EN</description>
                            <lsb>2</lsb>
                            <msb>2</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>Disable</name>
                                <description>rf reg is controlled by on chip logic</description>
                                <value>0</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>Enable</name>
                                <description>rf reg is controlled by external through SPI interface</description>
                                <value>1</value>
