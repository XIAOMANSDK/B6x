                                    <value>0x2</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>TRIGGER_LEVEL_3</name>
                                    <description>Trigger level 3 (14 characters or 0x0E).</description>
                                    <value>0x3</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>
