                            <msb>11</msb>
                        </field>

                        <field>
                            <name>FSH_PW_EN_DP</name>
                            <description>FSH_PW_EN_DP</description>
                            <lsb>12</lsb>
                            <msb>12</msb>
                        </field>

                        <field>
                            <name>CLK_STB_TIME</name>
                            <description>clock stable time for exit from deepsleep</description>
                            <lsb>16</lsb>
                            <msb>21</msb>
                        </field>

                        <field>
                            <name>WKUP_ST_CLR</name>
                            <description>WKUP_ST_CLR</description>
                            <lsb>22</lsb>
                            <msb>22</msb>
                        </field>

                        <field>
                            <name>AON_PMU_INT_CLR</name>
                            <description>AON_PMU_INT_CLR</description>
                            <lsb>23</lsb>
                            <msb>23</msb>
                        </field>

                    </fields>
                </register>

                <register>
                    <name>LDO_UD_CTRL</name>
