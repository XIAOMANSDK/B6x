                                    <name>TRIGGER_LEVEL_0</name>
                                    <description>Trigger level 0 (1 character or 0x01).</description>
                                    <value>0x0</value>
                                </enumeratedValue>
                                <enumeratedValue>
                                    <name>TRIGGER_LEVEL_1</name>
                                    <description>Trigger level 1 (4 characters or 0x04).</description>
                                    <value>0x1</value>
                                </enumeratedValue>
                                <enumeratedValue>
