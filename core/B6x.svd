                <register>
                    <name>RTC_ALARM_MS</name>
                    <description>RTC_ALARM_MS register</description>
                    <addressOffset>0x02C</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>RTC_SEC_SHD</name>
                    <description>RTC_SEC_SHD register</description>
                    <addressOffset>0x030</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>

                <register>
                    <name>RTC_MS_SHD</name>
                    <description>RTC_MS_SHD register</description>
                    <addressOffset>0x034</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                </register>


                <register>
                    <name>AON_PMU_CTRL</name>
                    <description>AON_PMU_CTRL register</description>
                    <addressOffset>0x038</addressOffset>
                    <access>read-write</access>
                    <resetValue>0x00000000</resetValue>
                    <resetMask>0xFFFFFFFF</resetMask>
                    <fields>
                        <field>
                            <name>LDO_LP_SEL_RUN</name>
                            <description>LDO_LP_SEL_RUN</description>
                            <lsb>0</lsb>
                            <msb>0</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>HP LDO Mode</name>
                                <description>CORE LDO is lp mode</description>
                                <value>1</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>LP LDO Mode</name>
                                <description>CORE LDO is HP mode</description>
                                <value>0</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>AON_PWR_SEL_RUN</name>
                            <description>AON_PWR_SEL_RUN</description>
                            <lsb>1</lsb>
                            <msb>1</msb>
                            <enumeratedValues>
                                <enumeratedValue>
                                <name>AON_LDO</name>
                                <description>select AON_LDO out as AON power</description>
                                <value>0</value>
                                </enumeratedValue>

                                <enumeratedValue>
                                <name>CORE_LDO</name>
                                <description>select CORE_LDO out as AON power</description>
                                <value>1</value>
                                </enumeratedValue>
                            </enumeratedValues>
                        </field>

                        <field>
                            <name>HSI_EN_RUN</name>
                            <description>HSI_EN_RUN</description>
                            <lsb>2</lsb>
                            <msb>2</msb>
                        </field>

                        <field>
                            <name>FSH_PW_EN_RUN</name>
                            <description>FSH_PW_EN_RUN</description>
                            <lsb>3</lsb>
                            <msb>3</msb>
                        </field>

                        <field>
                            <name>LDO_LP_SEL_DP</name>
                            <description>LDO_LP_SEL_DP</description>
                            <lsb>8</lsb>
                            <msb>8</msb>
                        </field>

                        <field>
                            <name>AON_PWR_SEL_DP</name>
                            <description>AON_PWR_SEL_DP</description>
                            <lsb>9</lsb>
                            <msb>9</msb>
                        </field>

                        <field>
                            <name>OSC_EN_DP</name>
                            <description>OSC_EN_DP</description>
                            <lsb>10</lsb>
                            <msb>10</msb>
                        </field>

                        <field>
                            <name>HSI_EN_DP</name>
