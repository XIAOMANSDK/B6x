{
    // 使用 IntelliSense 了解相关属性。
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug (JLink)",
            "cwd": "${workspaceFolder}",
            "executable": "${command:cmake.getLaunchTargetPath}",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "jlink",
            // 若系统未将 JLinkGDBServerCL.exe 加入 PATH，可在此处设置完整路径（按需修改）
            "serverpath": "C:/Program Files/SEGGER/JLink/JLinkGDBServerCL.exe",
            "interface": "swd",
            "device": "B6x",
            "svdFile": "${workspaceFolder}/core/B6x.svd",
            "preLaunchCommands": [
                "monitor reset",
                "monitor halt",
                "monitor reg pc = 0"
            ],
            "postRestartCommands": [
                "monitor halt"
            ],
            "haltAfterReset": true,
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        }
    ]
}
